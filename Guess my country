    end,
})

--- [[ Helper Logic ]] ---

local function FindGameUI()
    local player = game:GetService("Players").LocalPlayer
    local ui = player.PlayerGui:FindFirstChild("GuessPhaseUI", true)
    if ui then
        return ui.HintFrame.HintLabel, ui.WordBoxes
    end
    return nil, nil
end

local function GetPattern(WordBoxes)
    local pattern = ""
    local count = 0
    local children = WordBoxes:GetChildren()
    table.sort(children, function(a, b) return a.Name < b.Name end)

    for _, obj in ipairs(children) do
        if obj:IsA("GuiObject") then
            count = count + 1
            local letterObj = obj:FindFirstChild("Letter")
            if letterObj and letterObj.Text ~= "" and letterObj.Text ~= " " then
                pattern = pattern .. letterObj.Text:upper()
            else
                pattern = pattern .. "_"
            end
        end
    end
    return pattern, count
end

local function FilterCountries(pattern, boxCount)
    local matches = {}
    for _, country in ipairs(Countries) do
        local cleaned = country:upper():gsub("[%s%-%.'&,]", "")
        if #cleaned == boxCount then
            local isMatch = true
            for i = 1, #cleaned do
                local pChar = pattern:sub(i,i)
                if pChar ~= "_" and pChar ~= cleaned:sub(i,i) then
                    isMatch = false
                    break
                end
            end
            if isMatch then table.insert(matches, country) end
        end
    end
    return matches
end

local function AskAI(hints, filteredChoices)
    if LocalMode then 
        return filteredChoices[math.random(1, #filteredChoices)] 
    end
    if GroqAPIKey == "" or #hints == 0 or #filteredChoices == 0 then return nil end

    local prompt = "Hints: " .. table.concat(hints, " | ") .. ". Valid Choices: [" .. table.concat(filteredChoices, ", ") .. "]. Pick the most likely country."
    
    local success, response = pcall(function()
        return HttpService:RequestAsync({
            Url = "https://api.groq.com/openai/v1/chat/completions",
            Method = "POST",
            Headers = {["Authorization"] = "Bearer "..GroqAPIKey, ["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                model = "llama-3.3-70b-versatile",
                messages = {
                    {role = "system", content = "Output ONLY the country name."},
                    {role = "user", content = prompt}
                },
                temperature = 0.1
            })
        })
    end)

    if success and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        return data.choices[1].message.content:gsub("[^%a%s]", "")
    end
    return nil
end

-- Main Loop Logic
task.spawn(function()
    while task.wait(1.5) do
        local hintLabel, wordBoxes = FindGameUI()
        
        if hintLabel and wordBoxes then
            local pattern, boxCount = GetPattern(wordBoxes)
            local currentHint = hintLabel.Text

            if boxCount == 0 then
                RoundMemory = {}
                LastHint = ""
                CurrentAiGuess = ""
                PredictionDisplay:Set("Waiting...")
            elseif currentHint ~= "" then
                local statusCheck = currentHint .. pattern
                if statusCheck ~= LastStatus then
                    LastStatus = statusCheck
                    
                    if currentHint ~= LastHint then
                        LastHint = currentHint
                        table.insert(RoundMemory, currentHint)
                    end

                    local matches = FilterCountries(pattern, boxCount)
                    
                    if #matches == 1 then
                        CurrentAiGuess = matches[1]
                        PredictionDisplay:Set(CurrentAiGuess)
                    elseif #matches > 1 then
                        local result = AskAI(RoundMemory, matches)
                        if result then
                            CurrentAiGuess = result
                            PredictionDisplay:Set(result)
                        end
                    end
                end
            end
        end

        if AutoGuessLetters and CurrentAiGuess ~= "" and CurrentAiGuess ~= "Waiting..." then
            local cleanName = CurrentAiGuess:gsub("[%s%-%.'&,]", "")
            local randomChar = cleanName:sub(math.random(1, #cleanName), math.random(1, #cleanName))
            local remote = game:GetService("ReplicatedStorage").Remotes:FindFirstChild("GuessLetter")
            if remote then
                remote:FireServer(randomChar)
            end
        end
    end
end)
