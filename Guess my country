    PlaceholderText = "e.g. I_EL_ND",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        local pattern = Text:upper()
        local boxCount = #pattern
        local matches = {}

        if boxCount > 0 then
            for _, country in ipairs(Countries) do
                local cleaned = country:upper():gsub("[%s%-%.'&,]", "")
                if #cleaned == boxCount then
                    local isMatch = true
                    for i = 1, #cleaned do
                        local pChar = pattern:sub(i,i)
                        if pChar ~= "_" and pChar ~= cleaned:sub(i,i) then
                            isMatch = false
                            break
                        end
                    end
                    if isMatch then table.insert(matches, country) end
                end
            end
        end

        if #matches > 0 then
            PossibleListDisplay:Set({Title = "Matches Found ("..#matches..")", Content = table.concat(matches, ", ")})
        else
            PossibleListDisplay:Set({Title = "No Matches", Content = "Try adjusting the underscores or letters."})
