-- ============================================================
-- ANIMATIONS & LOGIC
-- ============================================================

local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function setLog(msg)
    logLabel.Text = "> " .. msg
end

local function flashBtn()
    -- Quick flash white then back
    local flash = TweenService:Create(toggleBtn, TweenInfo.new(0.08), {
        BackgroundColor3 = Color3.fromRGB(0, 255, 180),
        BackgroundTransparency = 0.1
    })
    flash:Play()
    flash.Completed:Connect(function()
        if active then
            TweenService:Create(toggleBtn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(0, 60, 40),
                BackgroundTransparency = 0.2
            }):Play()
        else
            TweenService:Create(toggleBtn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(0, 160, 100),
                BackgroundTransparency = 0.7
            }):Play()
        end
    end)
end

-- Pulse the stroke glow when active
local pulseActive = false
local function startPulse()
    pulseActive = true
    task.spawn(function()
        while pulseActive do
            TweenService:Create(mainStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Transparency = 0.1
            }):Play()
            task.wait(0.8)
            if not pulseActive then break end
            TweenService:Create(mainStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Transparency = 0.6
            }):Play()
            task.wait(0.8)
        end
    end)
end

local function stopPulse()
    pulseActive = false
    TweenService:Create(mainStroke, TweenInfo.new(0.3), { Transparency = 0.6 }):Play()
end

local function updateStats()
    if active and startTime > 0 then
        local elapsed = math.floor(tick() - startTime)
        statsLabel.Text = string.format("TELEPORTS: %d  |  TIME: %ds", teleportCount, elapsed)
    end
end

local function startScript()
    active = true
    teleportCount = 0
    startTime = tick()

    -- Update UI
    toggleBtn.Text = "■  TERMINATE SCRIPT"
    TweenService:Create(toggleBtn, tweenInfo, {
        BackgroundColor3 = Color3.fromRGB(0, 60, 40),
        BackgroundTransparency = 0.2
    }):Play()
    TweenService:Create(toggleStroke, tweenInfo, { Transparency = 0.0 }):Play()

    statusLabel.Text = "STATUS: ACTIVE ●"
    TweenService:Create(statusLabel, tweenInfo, {
        TextColor3 = Color3.fromRGB(0, 255, 180)
    }):Play()

    setLog("Script injected — looping at 0.15s")
    startPulse()

    -- Stats updater
    local statsConn
    statsConn = RunService.Heartbeat:Connect(function()
        if not active then
            statsConn:Disconnect()
            return
        end
        updateStats()
    end)

    -- Main loop
    loopConnection = task.spawn(function()
        while active do
            local character = player.Character or player.CharacterAdded:Wait()
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = target.CFrame + Vector3.new(0, 20, 0)
                teleportCount += 1
            end
            task.wait(0.15)
        end
    end)
end

local function stopScript()
    active = false
    loopConnection = nil

    -- Update UI
    toggleBtn.Text = "▶  EXECUTE SCRIPT"
    TweenService:Create(toggleBtn, tweenInfo, {
        BackgroundColor3 = Color3.fromRGB(0, 160, 100),
        BackgroundTransparency = 0.7
    }):Play()
    TweenService:Create(toggleStroke, tweenInfo, { Transparency = 0.5 }):Play()

    statusLabel.Text = "STATUS: INACTIVE"
    TweenService:Create(statusLabel, tweenInfo, {
        TextColor3 = Color3.fromRGB(255, 80, 80)
    }):Play()

    setLog(string.format("Stopped. %d teleports completed.", teleportCount))
    stopPulse()
end

