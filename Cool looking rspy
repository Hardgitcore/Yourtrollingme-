local function makePlayerRow(p)
    local row = Instance.new("TextButton")
    row.Size = UDim2.new(1, 0, 0, 24)
    row.BackgroundColor3 = Color3.fromRGB(20,20,32)
    row.BorderSizePixel = 0
    row.Text = p.Name
    row.TextColor3 = Color3.fromRGB(180,180,210)
    row.TextSize = 11
    row.Font = Enum.Font.GothamBold
    row.AutoButtonColor = false
    row.Parent = playerScroll
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)
    local rowStroke = makeStroke(row, Color3.fromRGB(50,50,80), 1, 0.5)
    selectedPlayerRows[p] = {row = row, stroke = rowStroke}
    row.MouseButton1Click:Connect(function()
        for _, item in pairs(selectedPlayerRows) do
            item.row.BackgroundColor3 = Color3.fromRGB(20,20,32)
            item.row.TextColor3 = Color3.fromRGB(180,180,210)
            item.stroke.Color = Color3.fromRGB(50,50,80)
        end
        if selectedPlayer == p then
            selectedPlayer = nil
        else
            selectedPlayer = p
            row.BackgroundColor3 = Color3.fromRGB(30,10,50)
            row.TextColor3 = Color3.fromRGB(200,100,255)
            rowStroke.Color = Color3.fromRGB(160,0,255)
        end
    end)
end

local function refreshPlayers()
    for _, child in ipairs(playerScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    selectedPlayerRows = {}
    local all = Players:GetPlayers()
    for _, p in ipairs(all) do makePlayerRow(p) end
    playerScroll.CanvasSize = UDim2.new(0,0,0,#all * 27 + 10)
end

Players.PlayerAdded:Connect(refreshPlayers)
Players.PlayerRemoving:Connect(function(p)
    if selectedPlayer == p then selectedPlayer = nil end
    refreshPlayers()
end)

