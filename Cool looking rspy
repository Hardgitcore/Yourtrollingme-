local function switchTab(index)
    for i, p in ipairs(panels) do p.Visible = i == index end
    for i, t in ipairs(tabBtns) do
        if i == index then
            t.btn.BackgroundColor3 = Color3.fromRGB(28,10,50)
            t.btn.TextColor3 = Color3.fromRGB(200,100,255)
            t.stroke.Color = Color3.fromRGB(160,0,255)
            t.stroke.Transparency = 0.2
        else
            t.btn.BackgroundColor3 = Color3.fromRGB(18,18,28)
            t.btn.TextColor3 = Color3.fromRGB(100,100,140)
            t.stroke.Color = Color3.fromRGB(40,40,60)
            t.stroke.Transparency = 0.5
        end
    end
end

