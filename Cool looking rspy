    local name = remote and remote.Name:lower() or ""
    if name:find("integrity") or name:find("anticheat") or name:find("detect") then
        tipsBox.BackgroundColor3 = Color3.fromRGB(22, 12, 12)
        makeStroke(tipsBox, Color3.fromRGB(180, 50, 50), 1, 0.3)
        tipsHeader.TextColor3 = Color3.fromRGB(220, 80, 80)
        tipsDot.BackgroundColor3 = Color3.fromRGB(220, 80, 80)
        tipsHeader.Text = "WARNING"
    elseif name:find("buy") or name:find("purchase") or name:find("reward") or name:find("give") then
        tipsBox.BackgroundColor3 = Color3.fromRGB(14, 20, 12)
        makeStroke(tipsBox, Color3.fromRGB(60, 180, 60), 1, 0.3)
        tipsHeader.TextColor3 = Color3.fromRGB(80, 220, 100)
        tipsDot.BackgroundColor3 = Color3.fromRGB(80, 220, 100)
        tipsHeader.Text = "TIP  (interesting)"
    else
        tipsBox.BackgroundColor3 = Color3.fromRGB(14, 12, 22)
        makeStroke(tipsBox, Color3.fromRGB(80, 40, 140), 1, 0.4)
        tipsHeader.TextColor3 = Color3.fromRGB(140, 60, 220)
        tipsDot.BackgroundColor3 = Color3.fromRGB(140, 60, 220)
        tipsHeader.Text = "TIP"
    end
end

local function updateSpyTips()
    if spyEnabled and logCount > 50 then
        spyTipsTxt.Text = SPY_TIPS.manyLogs
    elseif spyEnabled and logCount > 0 then
        spyTipsTxt.Text = SPY_TIPS.hasLogs
    elseif spyEnabled then
        spyTipsTxt.Text = SPY_TIPS.running
    else
        spyTipsTxt.Text = SPY_TIPS.idle
    end
end

-- hook into remote selection to update tips
-- patch the existing row click by wrapping updateTips into scanRemotes
local _originalMakeRemoteRow = makeRemoteRow
makeRemoteRow = function(remote)
    local item = _originalMakeRemoteRow(remote)
    local originalClick = item.row.MouseButton1Click
    item.row.MouseButton1Click:Connect(function()
        updateTips(remote)
    end)
    return item
end

-- spy tips auto-update
task.spawn(function()
    while true do
        updateSpyTips()
        task.wait(1)
    end
end)

