-- DECRYPTER LOGIC
-- ============================================================

local B64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

local function decodeBase64(data)
    data = data:gsub("[^"..B64.."=]", "")
    local result = {}
    local i = 1
    while i <= #data do
        local c1 = (B64:find(data:sub(i,i),1,true) or 1)-1
        local c2 = (B64:find(data:sub(i+1,i+1),1,true) or 1)-1
        local c3 = (B64:find(data:sub(i+2,i+2),1,true) or 1)-1
        local c4 = (B64:find(data:sub(i+3,i+3),1,true) or 1)-1
        local n = c1*262144 + c2*4096 + c3*64 + c4
        table.insert(result, string.char(math.floor(n/65536)%256))
        if data:sub(i+2,i+2) ~= "=" then table.insert(result, string.char(math.floor(n/256)%256)) end
        if data:sub(i+3,i+3) ~= "=" then table.insert(result, string.char(n%256)) end
        i = i + 4
    end
    return table.concat(result)
end

local function decodeHex(data)
    data = data:gsub("%s",""):gsub("0x","")
    local result = {}
    for i = 1, #data, 2 do
        local byte = tonumber(data:sub(i,i+1), 16)
        if byte then table.insert(result, string.char(byte)) end
    end
    return table.concat(result)
end

local function decodeROT13(data)
    return data:gsub("%a", function(c)
        local base = c:match("%l") and string.byte("a") or string.byte("A")
        return string.char((string.byte(c)-base+13)%26+base)
    end)
end

local function decodeReverse(data) return data:reverse() end

local function decodeXOR(data, key)
    key = key or 0x58
    local result = {}
    for i = 1, #data do
        table.insert(result, string.char(bit32.bxor(string.byte(data,i), key)))
    end
    return table.concat(result)
end

local function readabilityScore(text)
    local score = 0
    for _, kw in ipairs({"local","function","end","if","then","return","for","while","do","not","and","or","true","false","nil","print","game","workspace"}) do
        local _, count = text:gsub(kw, "")
        score = score + count * 3
    end
    local printable = 0
    for i = 1, #text do
        local b = string.byte(text, i)
        if b >= 32 and b <= 126 then printable += 1 end
    end
    score = score + ((#text > 0 and printable/#text or 0) * 20)
    return score
end

local function setDecryptStatus(text, color)
    decryptStatus.Text = "Detected: " .. text
    decryptStatus.TextColor3 = color or Color3.fromRGB(70,70,110)
end

local function tryDecode(method)
    local input = decryptInput.Text
    if input == "" then decryptOutput.Text = "-- No input" return end
    local ok3, result = pcall(function()
        if method == "base64"  then return decodeBase64(input)
        elseif method == "hex" then return decodeHex(input)
        elseif method == "rot13" then return decodeROT13(input)
        elseif method == "reverse" then return decodeReverse(input)
        elseif method == "xor" then return decodeXOR(input)
        end
    end)
    decryptOutput.Text = (ok3 and result and #result > 0) and result or "-- Decode failed or empty output"
end

local function autoDetect()
    local input = decryptInput.Text
    if input == "" then decryptOutput.Text = "-- No input" return end
    local attempts = {
        {name="Base64",         fn=function() return decodeBase64(input) end},
        {name="Hex",            fn=function() return decodeHex(input) end},
        {name="ROT13",          fn=function() return decodeROT13(input) end},
        {name="Reverse",        fn=function() return decodeReverse(input) end},
        {name="XOR 0x58",       fn=function() return decodeXOR(input,0x58) end},
        {name="XOR 0x1F",       fn=function() return decodeXOR(input,0x1F) end},
        {name="XOR 0x41",       fn=function() return decodeXOR(input,0x41) end},
        {name="Base64+ROT13",   fn=function() return decodeROT13(decodeBase64(input)) end},
        {name="ROT13+Base64",   fn=function() return decodeBase64(decodeROT13(input)) end},
        {name="Reverse+Base64", fn=function() return decodeBase64(decodeReverse(input)) end},
    }
    local best = {score=-1, result="", name="none"}
    for _, attempt in ipairs(attempts) do
        local ok3, result = pcall(attempt.fn)
        if ok3 and result and #result > 2 then
            local score = readabilityScore(result)
            if score > best.score then best = {score=score, result=result, name=attempt.name} end
        end
    end
    if best.score > 0 then
        decryptOutput.Text = best.result
        setDecryptStatus(best.name .. "  (score: "..math.floor(best.score)..")", Color3.fromRGB(80,220,100))
    else
        decryptOutput.Text = "-- Could not detect. May be Luraph/IronBrew/Prometheus bytecode -- cannot be decoded client-side."
        setDecryptStatus("unknown / advanced obfuscation", Color3.fromRGB(255,100,80))
    end
end

