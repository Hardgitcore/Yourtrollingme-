local function makeStroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(50,50,80)
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0.5
    s.Parent = parent
    return s
end

local function makeSectionLabel(parent, text, yPos)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, 0, 0, 13)
    l.Position = UDim2.new(0, 0, 0, yPos)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = Color3.fromRGB(70,70,110)
    l.TextSize = 9
    l.Font = Enum.Font.GothamBold
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = parent
    return l
end

local function makeBtn(parent, text, x, y, w, h, bg, tc, sc)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, w, 0, h)
    btn.Position = UDim2.new(0, x, 0, y)
    btn.BackgroundColor3 = bg
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = tc
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    makeStroke(btn, sc, 1, 0.3)
    return btn
end

-- Helper: Identify remotes that are likely anti-cheats or internal systems
local function isSafeRemote(remote)
    if not remote:IsA("RemoteEvent") then return false end -- Skip Functions (they hang loops)
    
    local name = remote.Name:lower()
    local blacklist = {
        "integrity", "anticheat", "detect", "ban", "kick", 
        "check", "teleport", "physics", "character", "appearance"
    }
    
    for _, word in ipairs(blacklist) do
        if name:find(word) then return false end
    end
    
    return true
end

