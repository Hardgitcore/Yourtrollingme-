local function getRemoteTip(remote)
    if not remote then return "Select a remote from the list on the left to get started." end

    local name = remote.Name:lower()
    local isFunc = remote:IsA("RemoteFunction")
    local tips = {}

    -- check for danger keywords first
    if name:find("integrity") or name:find("anticheat") or name:find("detect") then
        table.insert(tips, GENERIC_TIPS.integrity)
    elseif name:find("replication") or name:find("localization") then
        table.insert(tips, GENERIC_TIPS.replication)
    else
        -- keyword match
        local matched = false
        for keyword, tip in pairs(REMOTE_TIPS) do
            if name:find(keyword) then
                table.insert(tips, tip)
                matched = true
                break
            end
        end
        if not matched then
            -- generic tips
            if isFunc then
                table.insert(tips, GENERIC_TIPS.rf)
            else
                table.insert(tips, GENERIC_TIPS.re)
            end
        end
    end

    -- long name warning
    if #remote.Name > 40 then
        table.insert(tips, "Long name detected -- " .. GENERIC_TIPS.long)
    end

    -- add general advice
    table.insert(tips, "Path: " .. remote:GetFullName())

    return table.concat(tips, "  |  ")
end

