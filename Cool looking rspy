-- Tab width calculated to always fit 5 tabs inside 860px
local TAB_W = 158

local function makeTab(name, index)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, TAB_W, 0, 26)
    btn.BackgroundColor3 = index == 1 and Color3.fromRGB(28,10,50) or Color3.fromRGB(18,18,28)
    btn.BorderSizePixel = 0
    btn.Text = name
    btn.TextColor3 = index == 1 and Color3.fromRGB(200,100,255) or Color3.fromRGB(100,100,140)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.Parent = tabBar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local s = Instance.new("UIStroke")
    s.Color = index == 1 and Color3.fromRGB(160,0,255) or Color3.fromRGB(40,40,60)
    s.Thickness = 1
    s.Transparency = index == 1 and 0.2 or 0.5
    s.Parent = btn
    tabBtns[index] = {btn = btn, stroke = s}
    return btn
end

