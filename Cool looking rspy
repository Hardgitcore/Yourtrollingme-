local function parseArgs(text)
    if text == "" then return {} end
    local args = {}
    for part in text:gmatch("[^,]+") do
        local trimmed = part:match("^%s*(.-)%s*$")
        if trimmed == "true" then table.insert(args, true)
        elseif trimmed == "false" then table.insert(args, false)
        elseif tonumber(trimmed) then table.insert(args, tonumber(trimmed))
        else
            local stripped = trimmed:match('^"(.*)"$') or trimmed:match("^'(.*)'$") or trimmed
            table.insert(args, stripped)
        end
    end
    return args
end

local function argToString(arg)
    local t = type(arg)
    if t == "string"   then return '"' .. arg .. '"'
    elseif t == "boolean"  then return tostring(arg)
    elseif t == "number"   then return tostring(arg)
    elseif t == "userdata" then
        local ok3, name = pcall(function() return arg.Name end)
        return ok3 and ("Instance("..name..")") or "userdata"
    elseif t == "table" then return "{table}"
    else return tostring(arg) end
end

local function typeColor(arg)
    local t = type(arg)
    if t == "string"   then return Color3.fromRGB(255,180,80) end
    if t == "number"   then return Color3.fromRGB(120,200,255) end
    if t == "boolean"  then return Color3.fromRGB(180,120,255) end
    if t == "userdata" then return Color3.fromRGB(80,220,180) end
    return Color3.fromRGB(180,180,200)
end

local function fireRemote(remote, targetPlayer, args)
    if not remote then return false end
    local finalArgs = {}
    if bypassPlayerArg then table.insert(finalArgs, player) end
    if targetPlayer and targetPlayer ~= player then table.insert(finalArgs, targetPlayer) end
    for _, a in ipairs(args) do table.insert(finalArgs, a) end
    local ok3, err = pcall(function()
        if bypassInvoke then
            remote:InvokeServer(table.unpack(finalArgs))
        elseif remote:IsA("RemoteEvent") then
            remote:FireServer(table.unpack(finalArgs))
        elseif remote:IsA("RemoteFunction") then
            remote:InvokeServer(table.unpack(finalArgs))
        end
    end)
    if bypassSlowFire then task.wait(0.5) end
    return ok3, err
end

local function buildFireCode(remote, args)
    if not remote then return "-- No remote selected" end
    local path = remote:GetFullName()
    local method = (bypassInvoke or remote:IsA("RemoteFunction")) and "InvokeServer" or "FireServer"
    local argStr = bypassPlayerArg and "game.Players.LocalPlayer" or ""
    for i, a in ipairs(args) do
        if argStr ~= "" then argStr = argStr .. ", " end
        argStr = argStr .. argToString(a)
    end
    return string.format('-- Fire once\n-- Path: %s\nlocal remote = game:GetService("ReplicatedStorage"):WaitForChild("%s")\nremote:%s(%s)', path, remote.Name, method, argStr)
end

local function buildLoopCode(remote, args)
    if not remote then return "-- No remote selected" end
    local path = remote:GetFullName()
    local method = (bypassInvoke or remote:IsA("RemoteFunction")) and "InvokeServer" or "FireServer"
    local argStr = bypassPlayerArg and "game.Players.LocalPlayer" or ""
    for i, a in ipairs(args) do
        if argStr ~= "" then argStr = argStr .. ", " end
        argStr = argStr .. argToString(a)
    end
    local wait = bypassSlowFire and "0.5" or "0.1"
    return string.format('-- Loop fire\n-- Path: %s\nlocal remote = game:GetService("ReplicatedStorage"):WaitForChild("%s")\nwhile true do\n    remote:%s(%s)\n    task.wait(%s)\nend', path, remote.Name, method, argStr, wait)
end

local function buildHookCode(remote)
    if not remote then return "-- No remote selected" end
    return string.format(
'-- Hook & log: %s\nlocal oldNamecall\noldNamecall = hookmetamethod(game, "__namecall", function(self, ...)\n    local method = getnamecallmethod()\n    if self.Name == "%s" and (method == "FireServer" or method == "InvokeServer") then\n        local args = {...}\n        print("[RSpy] %s fired")\n        for i, arg in ipairs(args) do\n            print("  Arg "..i..": ["..type(arg).."] = "..tostring(arg))\n        end\n    end\n    return oldNamecall(self, ...)\nend)',
    remote.Name, remote.Name, remote.Name)
end

