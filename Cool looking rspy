local function startSpy()
    if not hookmetamethod then
        setStatus("hookmetamethod not available", Color3.fromRGB(255,80,80))
        return
    end
    spyEnabled = true
    spyToggleBtn.Text = "STOP SPY"
    spyToggleBtn.TextColor3 = Color3.fromRGB(255,100,100)
    
    -- List of remotes to block entirely
    local blockedRemotes = {
        ["updatecurretcall"] = true,
        ["updatecurrentcall"] = true -- Added the likely correct spelling just in case
    }

    hookRef = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local name = self.Name
        
        -- BLOCKING LOGIC: If the remote is in our list, stop it here
        if blockedRemotes[name:lower()] then
            return nil 
        end

        if spyEnabled and (method == "FireServer" or method == "InvokeServer" or method == "FireAllClients") then
            if self:IsA("RemoteEvent") or self:IsA("RemoteFunction") then
                local args = {...}
                local remoteType = self:IsA("RemoteFunction") and "RemoteFunction" or "RemoteEvent"
                task.defer(function()
                    addLogEntry(name, remoteType, method, args)
                end)
            end
        end
        return hookRef(self, ...)
    end)
end

local function stopSpy()
    spyEnabled = false
    spyToggleBtn.Text = "START SPY"
    spyToggleBtn.TextColor3 = Color3.fromRGB(80,220,100)
end

