Tabs.Main:AddButton({
    Title = "Scan Workspace",

    Callback = function()
        navResults = {}
        navPartMap = {}

        local search =
            string.lower(navSearchTerm or "")

        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then

                local lower =
                    string.lower(obj.Name)

                if search == ""
                    or string.find(
                        lower,
                        search,
                        1,
                        true
                    )
                then
                    local label =
                        obj.Name ..
                        " [" ..
                        (obj.Parent and obj.Parent.Name or "workspace")
                        .. "]"

                    table.insert(
                        navResults,
                        label
                    )

                    navPartMap[label] = obj

                    if #navResults >= 80 then
                        break
                    end
                end
            end
        end

        if #navResults <= 0 then
            navResults = {
                "No Results"
            }
        end

        ResultsDropdown:SetValues(navResults)
    end
})

