local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Players = game:GetService("Players")
local PathfindingService = game:GetService("PathfindingService")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local lp = Players.LocalPlayer
local Character, Humanoid, Root

--// SETTINGS
local Settings = {
    Enabled = false,
    WalkSpeed = 35,
    InteractionRadius = 35,

    FireClickDetectors = false,
    FirePrompts = false,

    TargetMode = "Exit",
}

--// STATE
local isNavigating = false
local reachedConn, blockedConn

local nextWaypointIndex = 1
local allWaypoints = {}

local stuckTimer = 0
local lastPos = Vector3.zero
local freeAttempts = 0

local currentSublevel = nil
local lastSuccessfulPath = {}

local navSearch = ""
local selectedPart = nil
local partMap = {}

--// CHARACTER
local function SetupCharacter()
    Character = lp.Character or lp.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    Root = Character:WaitForChild("HumanoidRootPart")

    Humanoid.WalkSpeed = Settings.WalkSpeed

    Humanoid.Died:Connect(function()
        isNavigating = false
    end)
end

SetupCharacter()

lp.CharacterAdded:Connect(function()
    task.wait(1)
    SetupCharacter()
end)

--// HELPERS
local function GetExit()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end

    local exitFolder = sub:FindFirstChild("Exit")
    if not exitFolder then return nil end

    return exitFolder:FindFirstChild("exit")
end

local function GetSublevelID()
    local exit = GetExit()
    if not exit then return "unknown" end

    local p = exit.Position

    return math.floor(p.X / 25) .. "_" .. math.floor(p.Z / 25)
end

--// CAMERA
local function FaceDirection(targetPos)
    if not Root then return end

    local dir = targetPos - Root.Position
    dir = Vector3.new(dir.X, 0, dir.Z)

    if dir.Magnitude <= 0.1 then
        return
    end

    local targetCF = CFrame.lookAt(
        Root.Position,
        Root.Position + dir
    )

    Root.CFrame = Root.CFrame:Lerp(targetCF, 0.18)

    local camPos =
        Root.Position
        - dir.Unit * 13
        + Vector3.new(0, 6, 0)

    local camCF = CFrame.lookAt(
        camPos,
        Root.Position + dir.Unit * 7
    )

    Camera.CameraType = Enum.CameraType.Scriptable
    Camera.CFrame = Camera.CFrame:Lerp(camCF, 0.12)
end

local function RestoreCamera()
    pcall(function()
        Camera.CameraType = Enum.CameraType.Custom
    end)
end

--// WALL DETECTION
local function GetWallPressure()
    if not Root then
        return Vector3.zero, 0
    end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {Character}

    local dirs = {
        Vector3.new(1,0,0),
        Vector3.new(-1,0,0),
        Vector3.new(0,0,1),
        Vector3.new(0,0,-1),

        Vector3.new(1,0,1).Unit,
        Vector3.new(-1,0,1).Unit,
        Vector3.new(1,0,-1).Unit,
        Vector3.new(-1,0,-1).Unit,
    }

    local pressure = Vector3.zero
    local walls = 0

    for _, dir in ipairs(dirs) do
        local result = workspace:Raycast(
            Root.Position,
            dir * 4,
            params
        )

        if result then
            pressure += (-dir * (4 - result.Distance))
            walls += 1
        end
    end

    return pressure, walls
end

--// UNSTICK
local function CameraUnstick()
    if not Root then return end

    Humanoid.Jump = true

    local angles = {90, -90, 180, 45}

    local angle = math.rad(
        angles[(freeAttempts % #angles) + 1]
    )

    local forward =
        (Root.CFrame * CFrame.Angles(0, angle, 0)).LookVector

    for i = 1, 12 do
        Root.CFrame += forward * 1.1
        task.wait(0.03)
    end

    freeAttempts += 1
end

--// NAVIGATION
local function stopNav()
    isNavigating = false

    if reachedConn then
        reachedConn:Disconnect()
        reachedConn = nil
    end

    if blockedConn then
        blockedConn:Disconnect()
        blockedConn = nil
    end

    allWaypoints = {}

    RestoreCamera()
end

local function MoveToWaypoint(index)
    if not allWaypoints[index] then
        stopNav()
        return
    end

    nextWaypointIndex = index

    local wp = allWaypoints[index]

    if wp.Action == Enum.PathWaypointAction.Jump then
        Humanoid.Jump = true
    end

    Humanoid:MoveTo(wp.Position)
end

local function BuildPath(destination)
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = true,
        WaypointSpacing = 3,
    })

    local success = pcall(function()
        path:ComputeAsync(Root.Position, destination)
    end)

    if not success then
        return nil
    end

    if path.Status ~= Enum.PathStatus.Success then
        return nil
    end

    return path
end

local function followPath(destination)
    if not Root or not Humanoid then
        return
    end

    stopNav()

    isNavigating = true
    stuckTimer = 0
    freeAttempts = 0
    lastPos = Root.Position

    local path = BuildPath(destination)

    if not path then
        Humanoid:MoveTo(destination)
        return
    end

    allWaypoints = path:GetWaypoints()

    if #allWaypoints <= 1 then
        stopNav()
        return
    end

    blockedConn = path.Blocked:Connect(function(blockedIdx)
        if blockedIdx >= nextWaypointIndex then
            stopNav()

            task.wait(0.1)

            followPath(destination)
        end
    end)

    reachedConn = Humanoid.MoveToFinished:Connect(function(reached)
        if not Settings.Enabled then
            stopNav()
            return
        end

        if reached then
            if nextWaypointIndex < #allWaypoints then
                MoveToWaypoint(nextWaypointIndex + 1)
            else
                lastSuccessfulPath[currentSublevel] = allWaypoints
                stopNav()
            end
        else
            stopNav()

            task.wait(0.1)

            followPath(destination)
        end
    end)

    MoveToWaypoint(2)
end

--// AUTO INTERACT
local function FireAura()
    if not Root then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        local parent = obj.Parent

        if parent and parent:IsA("BasePart") then
            local dist =
                (Root.Position - parent.Position).Magnitude

            if dist <= Settings.InteractionRadius then

                if obj:IsA("ClickDetector")
                and Settings.FireClickDetectors then

                    task.spawn(function()
                        pcall(function()
                            fireclickdetector(obj)
                        end)
                    end)
                end

                if obj:IsA("ProximityPrompt")
                and Settings.FirePrompts then

                    task.spawn(function()
                        pcall(function()
                            fireproximityprompt(obj)
                        end)
                    end)
                end
            end
        end
    end
end

--// MAIN LOOP
task.spawn(function()
    while true do
        task.wait(0.45)

        if not Settings.Enabled then
            continue
        end

        if not Root then
            continue
        end

        if isNavigating then
            continue
        end

        currentSublevel = GetSublevelID()

        local targetPos

        if Settings.TargetMode == "Exit" then
            local exit = GetExit()

            if exit then
                targetPos = exit.Position
            end
        else
            if selectedPart and selectedPart.Parent then
                targetPos = selectedPart.Position
            end
        end

        if targetPos then
            local dist =
                (Root.Position - targetPos).Magnitude

            if dist > 5 then
                followPath(targetPos)
            end
        end
    end
end)

--// HEARTBEAT
RunService.Heartbeat:Connect(function(dt)
    if not Settings.Enabled then
        RestoreCamera()
        return
    end

    if not Root or not Humanoid then
        return
    end

    Humanoid.WalkSpeed = Settings.WalkSpeed

    -- face direction
    if isNavigating
    and allWaypoints[nextWaypointIndex] then

        FaceDirection(
            allWaypoints[nextWaypointIndex].Position
        )
    end

    -- passive wall push
    local pressure, walls = GetWallPressure()

    if walls >= 3 and pressure.Magnitude > 0.1 then
        Root.CFrame +=
            Vector3.new(pressure.X, 0, pressure.Z).Unit * 0.3
    end

    -- stuck detection
    if isNavigating then
        local moved =
            (Root.Position - lastPos).Magnitude

        if moved < 0.4 then
            stuckTimer += dt
        else
            stuckTimer = 0
            lastPos = Root.Position
        end

        if stuckTimer >= 2 then
            stuckTimer = 0

            CameraUnstick()

            stopNav()

            task.wait(0.2)

            local target

            if Settings.TargetMode == "Exit" then
                local exit = GetExit()

                if exit then
                    target = exit.Position
                end
            else
                if selectedPart then
                    target = selectedPart.Position
                end
            end

            if target then
                followPath(target)
            end
        end
    end
end)

--// INTERACT LOOP
task.spawn(function()
    while true do
        task.wait(0.25)

        if Settings.Enabled then
            FireAura()
        end
    end
end)

