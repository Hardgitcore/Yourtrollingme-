--// NAV LOOP
task.spawn(function()
    while true do
        task.wait(0.45)

        if not Settings.Enabled
            or isNavigating
            or not Root
        then
            continue
        end

        local targetPos = nil

        -- EXIT
        if Settings.TargetMode == "Exit" then
            local exit = GetExit()

            if exit then
                targetPos = exit.Position
            end

        -- CUSTOM
        elseif selectedPart then
            targetPos = selectedPart.Position
        end

        if targetPos then
            if (Root.Position - targetPos).Magnitude > 5 then
                followPath(targetPos)
            else
                if Settings.TargetMode == "Custom Target" then
                    Fluent:Notify({
                        Title = "Arrived",
                        Content = "Target reached.",
                        Duration = 3
                    })

                    AutoToggle:SetValue(false)
                end
            end
        end
    end
end)

--// HEARTBEAT
RunService.Heartbeat:Connect(function(dt)
    if not Settings.Enabled
        or not Root
        or not Humanoid
    then
        return
    end

    if Humanoid.WalkSpeed ~= Settings.WalkSpeed then
        Humanoid.WalkSpeed = Settings.WalkSpeed
    end

    -- FACE WAYPOINT
    if isNavigating
        and allWaypoints[nextWaypointIndex]
    then
        FaceDirection(
            allWaypoints[nextWaypointIndex].Position
        )
    end

    -- PASSIVE WALL PUSH
    local pressure, count =
        GetWallPressure()

    if count >= 3
        and pressure.Magnitude > 0.1
    then
        local nudge =
            Vector3.new(
                pressure.X,
                0,
                pressure.Z
            ).Unit * 0.35

        Root.CFrame += nudge
    end

    -- STUCK DETECTION
    if isNavigating then
        local moved =
            (Root.Position - lastStuckPos).Magnitude

        if moved < 0.4 then
            stuckTimer += dt

            if stuckTimer >= 2 then
                stuckTimer = 0

                FreeFromWall()

                stopNav()
            end
        else
            stuckTimer = 0
            lastStuckPos = Root.Position
        end
    end
end)

--// INTERACTION LOOP
task.spawn(function()
    while true do
        task.wait(0.3)

        if Settings.Enabled then
            FireAura()
        end
    end
end)

