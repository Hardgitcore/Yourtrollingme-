--// CHARACTER SETUP
local function SetupCharacter()
    Character = lp.Character or lp.CharacterAdded:Wait()

    Humanoid = Character:WaitForChild("Humanoid")
    Root = Character:WaitForChild("HumanoidRootPart")

    Humanoid.Died:Connect(function()
        isNavigating = false

        pcall(function()
            Camera.CameraType = Enum.CameraType.Custom
        end)
    end)
end

SetupCharacter()

lp.CharacterAdded:Connect(function()
    task.wait(1)
    SetupCharacter()
end)

--// CAMERA + ROTATION
local function FaceDirection(targetPos)
    if not Root then
        return
    end

    local dir = targetPos - Root.Position
    dir = Vector3.new(dir.X, 0, dir.Z)

    if dir.Magnitude <= 0.1 then
        return
    end

    local targetCF = CFrame.lookAt(
        Root.Position,
        Root.Position + dir
    )

    Root.CFrame = Root.CFrame:Lerp(
        targetCF,
        0.22
    )

    if Camera.CameraType ~= Enum.CameraType.Scriptable then
        Camera.CameraType = Enum.CameraType.Scriptable
    end

    local camPos =
        Root.Position
        - dir.Unit * 14
        + Vector3.new(0, 7, 0)

    local camCF = CFrame.lookAt(
        camPos,
        Root.Position + dir * 8
    )

    Camera.CFrame = Camera.CFrame:Lerp(
        camCF,
        0.13
    )
end

local function RestoreCamera()
    pcall(function()
        Camera.CameraType = Enum.CameraType.Custom
    end)
end

--// EXIT
local function GetExit()
    local sub = workspace:FindFirstChild("Sublevel")

    if not sub then
        return nil
    end

    local exitFolder = sub:FindFirstChild("Exit")

    if not exitFolder then
        return nil
    end

    return exitFolder:FindFirstChild("exit")
end

--// STOP NAV
local function stopNav()
    isNavigating = false

    if reachedConn then
        reachedConn:Disconnect()
        reachedConn = nil
    end

    if blockedConn then
        blockedConn:Disconnect()
        blockedConn = nil
    end

    allWaypoints = {}
    nextWaypointIndex = 1

    RestoreCamera()
end

--// WALL DETECTION
local function GetWallPressure()
    if not Root then
        return Vector3.zero, 0
    end

    local params = RaycastParams.new()

    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {Character}

    local dirs = {
        Vector3.new(1,0,0),
        Vector3.new(-1,0,0),
        Vector3.new(0,0,1),
        Vector3.new(0,0,-1),

        Vector3.new(1,0,1).Unit,
        Vector3.new(-1,0,1).Unit,
        Vector3.new(1,0,-1).Unit,
        Vector3.new(-1,0,-1).Unit
    }

    local pressure = Vector3.zero
    local count = 0

    for _, dir in ipairs(dirs) do
        local result = workspace:Raycast(
            Root.Position,
            dir * 4,
            params
        )

        if result then
            pressure += (-dir * (4 - result.Distance))
            count += 1
        end
    end

    return pressure, count
end

--// ANTI STUCK
local function FreeFromWall()
    if not Root or not Humanoid then
        return
    end

    Humanoid.Jump = true

    local pressure = GetWallPressure()

    local push = pressure

    if typeof(pressure) == "table" then
        push = pressure[1]
    end

    if push.Magnitude > 0.1 then
        push = Vector3.new(
            push.X,
            0,
            push.Z
        ).Unit

        FaceDirection(
            Root.Position + push * 10
        )

        for i = 1, 12 do
            Root.CFrame += push * 1.15
            task.wait(0.03)
        end
    else
        local backwards =
            -Root.CFrame.LookVector

        for i = 1, 8 do
            Root.CFrame += backwards
            task.wait(0.03)
        end
    end
end

--// PATHFIND
local function followPath(destination)
    if not Root or not Humanoid then
        return
    end

    stopNav()

    isNavigating = true

    local path = PathfindingService:CreatePath({
        AgentRadius = 2.4,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = true,
        WaypointSpacing = 4
    })

    local success = pcall(function()
        path:ComputeAsync(
            Root.Position,
            destination
        )
    end)

    if not success
        or path.Status ~= Enum.PathStatus.Success
    then
        isNavigating = false

        Humanoid:MoveTo(destination)

        return
    end

    allWaypoints = path:GetWaypoints()

    if #allWaypoints < 2 then
        stopNav()
        return
    end

    blockedConn = path.Blocked:Connect(function(idx)
        if idx >= nextWaypointIndex then
            stopNav()

            task.wait(0.2)

            followPath(destination)
        end
    end)

    reachedConn = Humanoid.MoveToFinished:Connect(function(reached)
        if not Settings.Enabled then
            stopNav()
            return
        end

        if reached
            and nextWaypointIndex < #allWaypoints
        then
            nextWaypointIndex += 1

            local wp =
                allWaypoints[nextWaypointIndex]

            if wp.Action
                == Enum.PathWaypointAction.Jump
            then
                Humanoid.Jump = true
            end

            Humanoid:MoveTo(wp.Position)
        else
            stopNav()
        end
    end)

    nextWaypointIndex = 2

    local first =
        allWaypoints[nextWaypointIndex]

    if first then
        Humanoid:MoveTo(first.Position)
    end
end

--// INTERACT
local function FireAura()
    if not Root then
        return
    end

    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(function()

            -- CLICK DETECTORS
            if Settings.FireClickDetectors
                and obj:IsA("ClickDetector")
            then
                fireclickdetector(obj)
            end

            -- PROXIMITY PROMPTS
            if Settings.FirePrompts
                and obj:IsA("ProximityPrompt")
            then
                local parent = obj.Parent

                if parent
                    and parent:IsA("BasePart")
                then
                    local dist =
                        (Root.Position - parent.Position).Magnitude

                    if dist <= Settings.InteractionRadius then
                        fireproximityprompt(obj)
                    end
                end
            end

        end)
    end
end

