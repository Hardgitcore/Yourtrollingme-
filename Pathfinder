Tabs.Navigate:AddInput("Search", {
    Title = "Search Workspace",
    Placeholder = "Part Name",

    Callback = function(v)
        navSearch = v
    end
})

local ResultsDropdown =
    Tabs.Navigate:AddDropdown("Results", {
        Title = "Found Parts",
        Values = {"Scan workspace first"},
        Default = "Scan workspace first",

        Callback = function(v)
            selectedPart = partMap[v]
        end
    })

Tabs.Navigate:AddButton({
    Title = "Scan Workspace",

    Callback = function()
        local values = {}
        partMap = {}

        local search =
            tostring(navSearch):lower()

        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                if search == ""
                or obj.Name:lower():find(search, 1, true) then

                    local label =
                        obj.Name
                        .. " ["
                        .. (obj.Parent and obj.Parent.Name or "workspace")
                        .. "]"

                    table.insert(values, label)
                    partMap[label] = obj

                    if #values >= 75 then
                        break
                    end
                end
            end
        end

        if #values <= 0 then
            values = {"No results"}
        end

        ResultsDropdown:SetValues(values)
        ResultsDropdown:SetValue(values[1])

        selectedPart = partMap[values[1]]
    end
})

Tabs.Navigate:AddButton({
    Title = "Go To Selected Part",

    Callback = function()
        if not selectedPart then
            return
        end

        Settings.TargetMode = "Custom"

        followPath(selectedPart.Position)
    end
})

Tabs.Navigate:AddButton({
    Title = "Stop Navigation",

    Callback = function()
        stopNav()
    end
})

Window:SelectTab(1)

Fluent:Notify({
    Title = "Loaded",
    Content = "Navigator Ready",
    Duration = 5
})
