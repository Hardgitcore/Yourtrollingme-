-- // TOGGLE 1: Full Farming Loop
Tab:CreateToggle({
    Name = "AutoFarm",
    CurrentValue = false,
    Callback = function(Value)
        loopActive = Value

        task.spawn(function()
            local angle = 0
            local lastScanTime = 0
            local foundTargets = {}

            while loopActive do
                local char = player.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then
                    task.wait(1)
                    continue
                end
                
                local hrp = char.HumanoidRootPart
                
                -- Smart Scanner
                if tick() - lastScanTime >= 1 then
                    lastScanTime = tick()
                    foundTargets = {} 
                    
                    pcall(function()
                        local tempTargets = {}
                        
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v.Name:find("Remanat") and not IsDangerous(v) then
                                table.insert(tempTargets, v)
                            end
                        end
                        
                        for _, target in pairs(tempTargets) do
                            local pos = (target:IsA("Model") and target:GetPivot().Position) or (target:IsA("BasePart") and target.Position)
                            if pos and not IsPosNearTornado(pos) then
                                table.insert(foundTargets, target)
                            end
                        end
                    end)
                end
                
                -- Process Targets
                if #foundTargets > 0 then
                    pcall(function() hrp.Anchored = false end)
                    
                    for _, target in ipairs(foundTargets) do
                        if not loopActive then break end
                        
                        local targetValidAndSafe = false
                        pcall(function()
                            if target and target.Parent then
                                local pos = (target:IsA("Model") and target:GetPivot().Position) or (target:IsA("BasePart") and target.Position)
                                
                                -- Real-time Tornado check right before teleporting
                                if pos and not IsPosNearTornado(pos) then
                                    local targetCFrame = GetHighestPointCFrame(target)
                                    if targetCFrame then
                                        hrp.CFrame = targetCFrame
                                        targetValidAndSafe = true
                                    end
                                end
                            end
                        end)
                        
                        if targetValidAndSafe then
                            totalRemsTouched = totalRemsTouched + 1
                            RemsTouchedLabel:Set("Remnants Touched: " .. formatNumber(totalRemsTouched))
                            task.wait(0.25)
                        end
                    end
                    
                    foundTargets = {}
                    lastScanTime = 0 
                else
                    -- Idle Mode: Orbit Stud Border until area is clear
                    pcall(function()
                        hrp.Anchored = true
                        local centerPos = GetOrbitCenterPoint()
                        angle = angle + CIRCLE_SPEED
                        hrp.CFrame = CFrame.new(centerPos.X + (math.cos(angle) * CIRCLE_RADIUS), SKY_HEIGHT, centerPos.Z + (math.sin(angle) * CIRCLE_RADIUS))
                    end)
                    RunService.Heartbeat:Wait()
                end
            end
            
            -- Ground-Return Cleanup
            pcall(function()
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.Anchored = false
                    local map = workspace:FindFirstChild("ActiveMap")
                    local groundPos = (map and map:GetPivot().Position) or Vector3.new(0, 10, 0)
                    char.HumanoidRootPart.CFrame = CFrame.new(groundPos + Vector3.new(0, 5, 0))
                end
            end)
        end)
    end
})

