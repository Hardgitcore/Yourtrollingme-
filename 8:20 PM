-- Teleport button (instant, not toggle)
tpButton.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end

    local exit = sub:FindFirstChild("Exit")
    if not exit then return end

    -- ✅ If it's a BasePart
    if exit:IsA("BasePart") then
        root.CFrame = exit.CFrame + Vector3.new(0, 5, 0)

    -- ✅ If it's a Model
    elseif exit:IsA("Model") then
        local part = exit.PrimaryPart or exit:FindFirstChildWhichIsA("BasePart")
        if part then
            root.CFrame = part.CFrame + Vector3.new(0, 5, 0)
        end
    end
end)

-- Functions

local function deleteFakeWalls()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end

    local walls = sub:FindFirstChild("Walls")
    if not walls then return end

    local fakeWalls = walls:FindFirstChild("FakeWalls")
    if fakeWalls then
        for _, obj in ipairs(fakeWalls:GetChildren()) do
            pcall(function() obj:Destroy() end)
        end
    end
end

