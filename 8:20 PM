-- ============================================================
-- EXIT HELPERS
-- ============================================================

local function getExitPart()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end
    local exitModel = sub:FindFirstChild("Exit")
    if not exitModel then return nil end
    local part = exitModel:FindFirstChild("exit") or exitModel:FindFirstChildWhichIsA("BasePart")
    return part and part:IsA("BasePart") and part or nil
end

local function getExitPrompt()
    local part = getExitPart()
    return part and part:FindFirstChildWhichIsA("ProximityPrompt") or nil
end

local function getAltExitPart()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end
    for _, child in ipairs(sub:GetChildren()) do
        if child.Name:lower():find("alternate") then
            local part = child:FindFirstChild("exit") or child:FindFirstChildWhichIsA("BasePart")
            if part and part:IsA("BasePart") then return part end
        end
    end
    return nil
end

local function getAltExitPrompt()
    local part = getAltExitPart()
    return part and part:FindFirstChildWhichIsA("ProximityPrompt") or nil
end

