local function fireClicks()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            local ok = pcall(fireclickdetector, obj)
            if ok then firedCount += 1 countLabel.Text = "Fired: " .. firedCount end
        end
    end
end

local function deleteFake()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("fake") then pcall(function() obj:Destroy() end) end
    end
end

local function deleteWraith()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("wraith") then pcall(function() obj:Destroy() end) end
    end
end

local function deleteFakeWalls()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    local walls = sub:FindFirstChild("Walls")
    local fw = walls and walls:FindFirstChild("FakeWalls")
    if fw then
        for _, v in ipairs(fw:GetChildren()) do pcall(function() v:Destroy() end) end
    end
end

local function deleteWeak()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("weak") then pcall(function() obj:Destroy() end) end
    end
    for _, folderName in ipairs(LAP_FOLDERS) do
        local lap = sub:FindFirstChild(folderName)
        if lap then
            for _, obj in ipairs(lap:GetDescendants()) do
                if obj.Name:lower():find("weak") then pcall(function() obj:Destroy() end) end
            end
        end
    end
end

-- ============================================================
-- MAIN HEARTBEAT
-- ============================================================

RunService.Heartbeat:Connect(function(dt)
    if clickEnabled then fireClicks() end

    -- throttled deletions — run every 2 seconds to avoid lag
    if fakeEnabled then
        fakeTimer += dt
        if fakeTimer >= 2 then fakeTimer = 0 deleteFake() end
    end

    if wraithEnabled then
        wraithTimer += dt
        if wraithTimer >= 2 then wraithTimer = 0 deleteWraith() end
    end

    if wallsEnabled then
        wallsTimer += dt
        if wallsTimer >= 2 then wallsTimer = 0 deleteFakeWalls() end
    end

    if weakEnabled then
        weakTimer += dt
        if weakTimer >= 2 then weakTimer = 0 deleteWeak() end
    end

    if promptEnabled then
        local prompt = getExitPrompt()
        if prompt then
            prompt.MaxActivationDistance = math.huge
            prompt.RequiresLineOfSight = false
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = prompt.Parent.CFrame
                fireproximityprompt(prompt)
            end
        end
    end

    if altPromptEnabled then
        local prompt = getAltExitPrompt()
        if prompt then
            prompt.MaxActivationDistance = math.huge
            prompt.RequiresLineOfSight = false
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = prompt.Parent.CFrame
                fireproximityprompt(prompt)
            end
        end
    end
end)

