    state = not state
    btn.Text = state and "Disable" or "Enable"
    btn.BackgroundColor3 = state and Color3.fromRGB(200,60,60) or color
    return state
end

-- ============================================================
-- ESP CORE
-- ============================================================

-- Highlight one object (Model or BasePart), parent to screenGui so it
-- survives the object being destroyed
local function highlightObject(obj)
    if espTagged[obj] then return end  -- already tagged

    local h = Instance.new("Highlight")
    h.Name = "WraithESP"
    h.FillColor = Color3.fromRGB(255, 80, 80)
    h.FillTransparency = 0.5
    h.OutlineColor = Color3.fromRGB(255, 80, 80)
    h.OutlineTransparency = 0
    h.Adornee = obj
    h.Parent = screenGui   -- survives obj:Destroy()

    espTagged[obj] = h
    table.insert(espHighlights, h)
end

-- Scan a container (WraithWalls folder) and highlight everything inside
local function scanContainer(container)
    for _, obj in ipairs(container:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("BasePart") then
            highlightObject(obj)
        end
    end
    -- Also highlight the container's direct children that are parts/models
    if container:IsA("Model") or container:IsA("BasePart") then
        highlightObject(container)
    end
end

-- Watch a single WraithWalls container for new descendants
local function watchContainer(container)
    local conn = container.DescendantAdded:Connect(function(obj)
        if not espEnabled then return end
        if obj:IsA("Model") or obj:IsA("BasePart") then
            -- Small wait so the object is fully added before highlighting
            task.defer(function()
                if espEnabled then
                    highlightObject(obj)
                    -- If wraithEnabled, delete it too
                    if wraithEnabled then
                        pcall(function() obj:Destroy() end)
                    end
                end
            end)
        end
    end)
    table.insert(espConnections, conn)
end

-- Find all WraithWalls containers inside a given Sublevel
local function findWraithContainers(sub)
    local found = {}

    local function checkParent(parent)
        -- parent > Walls > WraithWalls
        local walls = parent:FindFirstChild("Walls")
        if walls then
            local ww = walls:FindFirstChild("WraithWalls")
            if ww then table.insert(found, ww) end
        end
        -- parent > WraithWalls directly
        local ww2 = parent:FindFirstChild("WraithWalls")
        if ww2 then table.insert(found, ww2) end
    end

    checkParent(sub)

    for _, child in ipairs(sub:GetChildren()) do
        -- LAP folders, numbered folders, any Folder
        local n = child.Name:lower()
        if child:IsA("Folder") or n:find("lap") or n:find("level") or n:find("room") then
            checkParent(child)
        end
    end

    return found
end

-- Disconnect all ESP listeners and clear highlights
local function clearESP()
    for _, c in ipairs(espConnections) do
        pcall(function() c:Disconnect() end)
    end
    espConnections = {}

    for _, h in ipairs(espHighlights) do
        pcall(function() h:Destroy() end)
    end
    espHighlights = {}
    espTagged = {}
end

-- Full attach: scan existing containers + watch for new descendants
-- Also watches the Sublevel itself for new Walls/LAP folders appearing
local function attachESP(sub)
    -- Scan + watch currently existing containers
    for _, container in ipairs(findWraithContainers(sub)) do
        scanContainer(container)
        watchContainer(container)
    end

    -- Watch Sublevel for new children (e.g. new Walls or LAP folder added mid-game)
    local subConn = sub.DescendantAdded:Connect(function(obj)
        if not espEnabled then return end

        -- If a new WraithWalls folder appears anywhere under the sublevel
        if obj.Name == "WraithWalls" then
            task.defer(function()
                if espEnabled then
                    scanContainer(obj)
                    watchContainer(obj)
                end
            end)
        end
    end)
    table.insert(espConnections, subConn)
end

-- ============================================================
-- WORKSPACE WATCHER
-- Handles the Sublevel being replaced entirely (new round/map load)
-- ============================================================
local subLevelWatcher = nil

local function startSubLevelWatcher()
    if subLevelWatcher then
        pcall(function() subLevelWatcher:Disconnect() end)
        subLevelWatcher = nil
    end

    -- Attach to current Sublevel if it exists
    local sub = workspace:FindFirstChild("Sublevel")
    if sub and espEnabled then
        attachESP(sub)
    end

    -- Watch for Sublevel being added (new round starts)
    subLevelWatcher = workspace.ChildAdded:Connect(function(child)
        if child.Name == "Sublevel" then
            task.defer(function()
                -- Re-clear so old highlights don't stack
                clearESP()
                if espEnabled then
                    attachESP(child)
                    -- Re-attach the watcher since clearESP disconnected it
                    startSubLevelWatcher()
                end
                -- If wraith delete is on, kill all wraith objects in new sublevel
                if wraithEnabled then
                    for _, obj in ipairs(child:GetDescendants()) do
                        if obj.Name:lower():find("wraith") then
                            pcall(function() obj:Destroy() end)
                        end
                    end
                end
            end)
        end
    end)
end

