    if child.Name == "Sublevel" and wraithEnabled then
        task.defer(function()
            for _, obj in ipairs(child:GetDescendants()) do
                if obj.Name:lower():find("wraith") then
                    pcall(function() obj:Destroy() end)
                end
            end
        end)
    end
end)
