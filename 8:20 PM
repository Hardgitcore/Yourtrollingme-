-- path: workspace.Sublevel.Exit (Model) → Exit (Part)
local function getExitPart()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end
    local exitModel = sub:FindFirstChild("Exit")
    if not exitModel then return nil end
    -- it's a Model — find the Part named Exit inside it
    if exitModel:IsA("Model") then
        local part = exitModel:FindFirstChild("Exit")
        if part and part:IsA("BasePart") then return part end
        -- fallback: any basepart inside
        return exitModel:FindFirstChildWhichIsA("BasePart")
    end
    -- fallback if somehow it is a part directly
    if exitModel:IsA("BasePart") then return exitModel end
    return nil
end

local function getExitPrompt()
    local part = getExitPart()
    if not part then return nil end
    return part:FindFirstChildWhichIsA("ProximityPrompt")
end

local LAP_FOLDERS = {"Lap1","Lap2","Lap3","Lap4"}

local function scanAndDelete(folder, keyword)
    if not folder then return end
    for _, obj in ipairs(folder:GetChildren()) do
        if obj.Name:lower():find(keyword) then
            pcall(function() obj:Destroy() end)
        end
    end
end

