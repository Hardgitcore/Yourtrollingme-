    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = mainFrame

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 32)
    btn.Position = UDim2.new(0, 10, 0, yPos + 18)
    btn.BackgroundColor3 = color
