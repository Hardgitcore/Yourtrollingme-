local function flip(btn, state, color)
    state = not state
    btn.Text = state and "Disable" or "Enable"
    btn.BackgroundColor3 = state and Color3.fromRGB(200,60,60) or color
    return state
end

-- ============================================================
-- HIDE PLAYERS
-- ============================================================

local function setCharacterVisible(char, visible)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.LocalTransparencyModifier = visible and 0 or 1
        end
        if part:IsA("Humanoid") then
            part.DisplayDistanceType  = visible
                and Enum.HumanoidDisplayDistanceType.Viewer
                or  Enum.HumanoidDisplayDistanceType.None
            part.NameDisplayDistance   = visible and 100 or 0
            part.HealthDisplayDistance = visible and 100 or 0
        end
    end
end

local function applyHideToPlayer(p)
    if p == player then return end
    if p.Character then
        setCharacterVisible(p.Character, false)
    end
    if hideConnections[p] then
        pcall(function() hideConnections[p]:Disconnect() end)
    end
    hideConnections[p] = p.CharacterAdded:Connect(function(char)
        if hideEnabled then
            task.defer(function()
                setCharacterVisible(char, false)
            end)
        end
    end)
end

local function restorePlayer(p)
    if p == player then return end
    if p.Character then
        setCharacterVisible(p.Character, true)
    end
    if hideConnections[p] then
        pcall(function() hideConnections[p]:Disconnect() end)
        hideConnections[p] = nil
    end
end

local function enableHidePlayers()
    for _, p in ipairs(Players:GetPlayers()) do
        applyHideToPlayer(p)
    end
    playerAddedConn = Players.PlayerAdded:Connect(function(p)
        if hideEnabled then applyHideToPlayer(p) end
    end)
end

local function disableHidePlayers()
    for _, p in ipairs(Players:GetPlayers()) do
        restorePlayer(p)
    end
    if playerAddedConn then
        pcall(function() playerAddedConn:Disconnect() end)
        playerAddedConn = nil
    end
end

-- ============================================================
-- ENTITY PREVENTION BUBBLE
-- ============================================================

function buildEPParts()
    destroyEPParts()
    for i = 1, EP_COUNT do
        local part = Instance.new("Part")
        part.Name = "EPBubble_" .. i
        part.Size = EP_SIZE
        part.Anchored = true
        part.CanCollide = true
        part.Transparency = 0.7
        part.Material = Enum.Material.ForceField
        part.Color = Color3.fromRGB(80, 255, 200)
        part.Parent = workspace
        table.insert(epParts, part)
    end
end

function destroyEPParts()
    for _, part in ipairs(epParts) do
        pcall(function() part:Destroy() end)
    end
    epParts = {}
end

-- ============================================================
-- ESP CORE
-- ============================================================

local function highlightObject(obj)
    if espTagged[obj] then return end
    local h = Instance.new("Highlight")
    h.Name = "WraithESP"
    h.FillColor = Color3.fromRGB(255, 80, 80)
    h.FillTransparency = 0.5
    h.OutlineColor = Color3.fromRGB(255, 80, 80)
    h.OutlineTransparency = 0
    h.Adornee = obj
    h.Parent = workspace
    espTagged[obj] = h
    table.insert(espHighlights, h)
end

local function scanContainer(container)
    for _, obj in ipairs(container:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("BasePart") then
            highlightObject(obj)
        end
    end
    if container:IsA("Model") or container:IsA("BasePart") then
        highlightObject(container)
    end
end

local function watchContainer(container)
    local conn = container.DescendantAdded:Connect(function(obj)
        if not espEnabled then return end
        if obj:IsA("Model") or obj:IsA("BasePart") then
            task.defer(function()
                if espEnabled then
                    highlightObject(obj)
                    if wraithEnabled then
                        pcall(function() obj:Destroy() end)
                    end
                end
            end)
        end
    end)
    table.insert(espConnections, conn)
end

local function findWraithContainers(sub)
    local found = {}
    local function checkParent(parent)
        local walls = parent:FindFirstChild("Walls")
        if walls then
            local ww = walls:FindFirstChild("WraithWalls")
            if ww then table.insert(found, ww) end
        end
        local ww2 = parent:FindFirstChild("WraithWalls")
        if ww2 then table.insert(found, ww2) end
    end
    checkParent(sub)
    for _, child in ipairs(sub:GetChildren()) do
        local n = child.Name:lower()
        if child:IsA("Folder") or n:find("lap") or n:find("level") or n:find("room") then
            checkParent(child)
        end
    end
    return found
end

local function clearESP()
    for _, c in ipairs(espConnections) do
        pcall(function() c:Disconnect() end)
    end
    espConnections = {}
    for _, h in ipairs(espHighlights) do
        pcall(function() h:Destroy() end)
    end
    espHighlights = {}
    espTagged = {}
end

local function attachESP(sub)
    for _, container in ipairs(findWraithContainers(sub)) do
        scanContainer(container)
        watchContainer(container)
    end
    local subConn = sub.DescendantAdded:Connect(function(obj)
        if not espEnabled then return end
        if obj.Name == "WraithWalls" then
            task.defer(function()
                if espEnabled then
                    scanContainer(obj)
                    watchContainer(obj)
                end
            end)
        end
    end)
    table.insert(espConnections, conn)
end

-- ============================================================
-- SUBLEVEL WATCHER
-- ============================================================

local function startSubLevelWatcher()
    if subLevelWatcher then
        pcall(function() subLevelWatcher:Disconnect() end)
        subLevelWatcher = nil
    end
    local sub = workspace:FindFirstChild("Sublevel")
    if sub and espEnabled then
        attachESP(sub)
    end
    subLevelWatcher = workspace.ChildAdded:Connect(function(child)
        if child.Name == "Sublevel" then
            task.defer(function()
                clearESP()
                if espEnabled then
                    attachESP(child)
                    startSubLevelWatcher()
                end
                if wraithEnabled then
                    for _, obj in ipairs(child:GetDescendants()) do
                        if obj.Name:lower():find("wraith") then
                            pcall(function() obj:Destroy() end)
                        end
                    end
                end
                -- Re-apply instant prompt if enabled
                if instantPromptEnabled then
                    task.wait(0.5)
                    applyInstantPrompt()
                end
            end)
        end
    end)
end

-- ============================================================
-- EXIT HELPERS
-- ============================================================
-- Hierarchy: workspace.Sublevel.Exit.exit.ProximityPrompt

local function findExitPart()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end
    
    local exitModel = sub:FindFirstChild("Exit")
    if not exitModel then return nil end
    
    -- Look for part named "exit" (lowercase based on your hierarchy)
    local exitPart = exitModel:FindFirstChild("exit")
    if exitPart and exitPart:IsA("BasePart") then
        return exitPart
    end
    
    -- Fallback: case-insensitive search
    for _, child in ipairs(exitModel:GetChildren()) do
        if child:IsA("BasePart") and child.Name:lower() == "exit" then
            return child
        end
    end
    
    return nil
end

local function findExitProximityPrompt()
    local exitPart = findExitPart()
    if not exitPart then 
        warn("Exit part not found. Looking for: workspace.Sublevel.Exit.exit")
        return nil 
    end
    
    -- ProximityPrompt should be directly inside the exit part
    local prompt = exitPart:FindFirstChildOfClass("ProximityPrompt")
    if prompt then
        return prompt
    end
    
    warn("ProximityPrompt not found in exit part:", exitPart:GetFullName())
    return nil
end

-- ============================================================
-- INSTANT PROXIMITY PROMPT SYSTEM
-- ============================================================

local function applyInstantPrompt()
    local prompt = findExitProximityPrompt()
    if not prompt then
        countLabel.Text = "Exit prompt not found!"
        return false
    end
    
    -- Store original settings if not already stored
    if not originalPromptSettings[prompt] then
        originalPromptSettings[prompt] = {
            MaxActivationDistance = prompt.MaxActivationDistance,
            HoldDuration = prompt.HoldDuration,
            RequiresLineOfSight = prompt.RequiresLineOfSight
        }
    end
    
    -- Apply instant settings
    prompt.MaxActivationDistance = math.huge
    prompt.HoldDuration = 0
    prompt.RequiresLineOfSight = false
    
    countLabel.Text = "Instant Prompt: ON"
    return true
end

local function restorePrompt()
    local prompt = findExitProximityPrompt()
    if not prompt then return end
    
    -- Restore original settings
    if originalPromptSettings[prompt] then
        prompt.MaxActivationDistance = originalPromptSettings[prompt].MaxActivationDistance
        prompt.HoldDuration = originalPromptSettings[prompt].HoldDuration
        prompt.RequiresLineOfSight = originalPromptSettings[prompt].RequiresLineOfSight
        originalPromptSettings[prompt] = nil
    end
    
    countLabel.Text = "Instant Prompt: OFF"
end

local function watchForExitPrompt()
    if exitPromptConnection then
        pcall(function() exitPromptConnection:Disconnect() end)
    end
    
    exitPromptConnection = workspace.DescendantAdded:Connect(function(descendant)
        if not instantPromptEnabled then return end
        
        if descendant:IsA("ProximityPrompt") then
            local part = descendant.Parent
            if part and part.Name:lower() == "exit" then
                task.wait(0.1)
                applyInstantPrompt()
            end
        end
    end)
end

