-- ============================================================
-- EXIT HELPERS
-- ============================================================

local function getExitPart()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end
    local exitModel = sub:FindFirstChild("Exit")
    if not exitModel then return nil end
    local part = exitModel:FindFirstChild("exit") or exitModel:FindFirstChildWhichIsA("BasePart")
    return part and part:IsA("BasePart") and part or nil
end

local function getExitPrompt()
    local part = getExitPart()
    return part and part:FindFirstChildWhichIsA("ProximityPrompt") or nil
end

local function getAltExitPart()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return nil end
    for _, child in ipairs(sub:GetChildren()) do
        if child.Name:lower():find("alternate") then
            local part = child:FindFirstChild("exit") or child:FindFirstChildWhichIsA("BasePart")
            if part and part:IsA("BasePart") then return part end
        end
    end
    return nil
end

local function getAltExitPrompt()
    local part = getAltExitPart()
    return part and part:FindFirstChildWhichIsA("ProximityPrompt") or nil
end

-- ============================================================
-- HIDE PLAYERS
-- ============================================================

local function setCharacterVisible(char, visible)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.LocalTransparencyModifier = visible and 0 or 1 end
    end
end

local function applyHideToPlayer(p)
    if p == player then return end
    if p.Character then setCharacterVisible(p.Character, false) end
    hideConnections[p] = p.CharacterAdded:Connect(function(char)
        if hideEnabled then task.defer(function() setCharacterVisible(char, false) end) end
    end)
end

local function restorePlayer(p)
    if p == player then return end
    if p.Character then setCharacterVisible(p.Character, true) end
    if hideConnections[p] then
        pcall(function() hideConnections[p]:Disconnect() end)
        hideConnections[p] = nil
    end
end

-- ============================================================
-- ESP CORE 
-- ============================================================

local espTagged     = {}  -- [object] = { part, highlight }
local espHighlights = {}  -- flat list of { part, highlight } for cleanup
local espConnections = {}

local function highlightObject(obj)
    if espTagged[obj] then return end

    -- Get a position/size reference from the object
    local refPart = nil
    if obj:IsA("BasePart") then
        refPart = obj
    elseif obj:IsA("Model") then
        refPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    end
    if not refPart then return end

    -- Create a ghost part that sits on top of the wraith object
    local ghost = Instance.new("Part")
    ghost.Name             = "WraithESP_Ghost"
    ghost.Size             = refPart.Size
    ghost.CFrame           = refPart.CFrame
    ghost.Anchored         = true
    ghost.CanCollide       = false
    ghost.CanTouch         = false
    ghost.CanQuery         = false
    ghost.CastShadow       = false
    ghost.Transparency     = 1          -- fully invisible part
    ghost.Parent           = workspace

    -- Highlight on the ghost — DepthMode = AlwaysOnTop so it shows through walls
    local h = Instance.new("Highlight")
    h.Name                 = "WraithESP"
    h.FillColor            = Color3.fromRGB(255, 80, 80)
    h.FillTransparency     = 1          -- no fill, only outline
    h.OutlineColor         = Color3.fromRGB(255, 80, 80)
    h.OutlineTransparency  = 0
    h.DepthMode            = Enum.HighlightDepthMode.AlwaysOnTop  -- goes through walls
    h.Adornee              = ghost
    h.Parent               = workspace

    -- Track the original object so we can update ghost CFrame each frame
    espTagged[obj] = { ghost = ghost, highlight = h, ref = refPart }
    table.insert(espHighlights, espTagged[obj])
end

local function scanContainer(container)
    for _, obj in ipairs(container:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("BasePart") then
            highlightObject(obj)
        end
    end
    if container:IsA("Model") or container:IsA("BasePart") then
        highlightObject(container)
    end
end

local function watchContainer(container)
    local conn = container.DescendantAdded:Connect(function(obj)
        if not espEnabled then return end
        if obj:IsA("Model") or obj:IsA("BasePart") then
            task.defer(function()
                if espEnabled then
                    highlightObject(obj)
                    if wraithEnabled then
                        pcall(function() obj:Destroy() end)
                    end
                end
            end)
        end
    end)
    table.insert(espConnections, conn)
end

local function clearESP()
    for _, c in ipairs(espConnections) do
        pcall(function() c:Disconnect() end)
    end
    espConnections = {}

    for _, entry in ipairs(espHighlights) do
        pcall(function() entry.highlight:Destroy() end)
        pcall(function() entry.ghost:Destroy() end)
    end
    espHighlights = {}
    espTagged = {}
end

-- Update ghost CFrames every Heartbeat so they follow moving wraith parts
RunService.Heartbeat:Connect(function()
    if not espEnabled then return end
    for obj, entry in pairs(espTagged) do
        -- If the original object was destroyed, clean up this entry
        if not entry.ref or not entry.ref.Parent then
            pcall(function() entry.highlight:Destroy() end)
            pcall(function() entry.ghost:Destroy() end)
            espTagged[obj] = nil
        else
            -- Keep ghost snapped to the real part
            entry.ghost.CFrame = entry.ref.CFrame
        end
    end
end)

-- ============================================================
-- SUBLEVEL WATCHER
-- ============================================================

local function startSubLevelWatcher()
    if subLevelWatcher then pcall(function() subLevelWatcher:Disconnect() end) end
    subLevelWatcher = workspace.ChildAdded:Connect(function(child)
        if child.Name == "Sublevel" then
            task.defer(function()
                if espEnabled then clearESP() scanContainer(child) end
                if wraithEnabled then
                    for _, obj in ipairs(child:GetDescendants()) do
                        if obj.Name:lower():find("wraith") then pcall(function() obj:Destroy() end) end
                    end
                end
                if weakEnabled then
                    for _, obj in ipairs(child:GetDescendants()) do
                        if obj.Name:lower():find("weak") then pcall(function() obj:Destroy() end) end
                    end
                end
            end)
        end
    end)
end

-- ============================================================
-- HEARTBEAT FUNCTIONS
-- ============================================================

local function fireClicks()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            local ok = pcall(fireclickdetector, obj)
            if ok then firedCount += 1 end
        end
    end
end

local function deleteFake()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("fake") then pcall(function() obj:Destroy() end) end
    end
end

local function deleteWraith()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("wraith") then pcall(function() obj:Destroy() end) end
    end
end

local function deleteFakeWalls()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    local walls = sub:FindFirstChild("Walls")
    local fw = walls and walls:FindFirstChild("FakeWalls")
    if fw then
        for _, v in ipairs(fw:GetChildren()) do pcall(function() v:Destroy() end) end
    end
end

local function deleteWeak()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("weak") then pcall(function() obj:Destroy() end) end
    end
    for _, folderName in ipairs(LAP_FOLDERS) do
        local lap = sub:FindFirstChild(folderName)
        if lap then
            for _, obj in ipairs(lap:GetDescendants()) do
                if obj.Name:lower():find("weak") then pcall(function() obj:Destroy() end) end
            end
        end
    end
end

