local function flipBtn(btn, current, onColor)
    local new = not current
    btn.Text = new and "Disable" or "Enable"
    btn.BackgroundColor3 = new and Color3.fromRGB(200, 60, 60) or onColor
    return new
end

clickToggle.MouseButton1Click:Connect(function()
    clickEnabled = flipBtn(clickToggle, clickEnabled, Color3.fromRGB(60,130,220))
end)

