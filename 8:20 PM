local function makeToggle(labelText, yPos, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 0, 16)
    label.Position = UDim2.new(0, 10, 0, yPos)
    label.BackgroundTransparency = 1
