-- LocalScript

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ClickDetectorFirer"
screenGui.ResetOnSpawn = false
screenGui.Parent = player.PlayerGui

-- Main Frame
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 230, 0, 340)
mainFrame.Position = UDim2.new(0, 20, 0.5, -170)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 8)

-- Title Bar
local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 36)
titleBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
titleBar.BorderSizePixel = 0
titleBar.Parent = mainFrame

Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 8)

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 1, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "🖱 Click Detector Firer"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextSize = 14
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = titleBar

-- Toggles
local clickToggle  = makeToggle("Click Detectors", 20, Color3.fromRGB(60,130,220))
local fakeToggle   = makeToggle("Delete Fake Objects", 70, Color3.fromRGB(160,100,30))
local wraithToggle = makeToggle("Delete Wraith Objects", 120, Color3.fromRGB(80,50,160))
local wallsToggle  = makeToggle("Delete FakeWalls", 170, Color3.fromRGB(200,120,40))
local espToggle    = makeToggle("Wraith ESP", 220, Color3.fromRGB(200,80,80))
local tpButton     = makeToggle("Teleport to Exit", 270, Color3.fromRGB(60,180,100))

-- States
local clickEnabled, fakeEnabled, wraithEnabled, wallsEnabled, espEnabled = false,false,false,false,false

local function flip(btn, state, color)
    state = not state
    btn.Text = state and "Disable" or "Enable"
    btn.BackgroundColor3 = state and Color3.fromRGB(200,60,60) or color
    return state
end

clickToggle.MouseButton1Click:Connect(function()
    clickEnabled = flip(clickToggle, clickEnabled, Color3.fromRGB(60,130,220))
end)

fakeToggle.MouseButton1Click:Connect(function()
    fakeEnabled = flip(fakeToggle, fakeEnabled, Color3.fromRGB(160,100,30))
end)

wraithToggle.MouseButton1Click:Connect(function()
    wraithEnabled = flip(wraithToggle, wraithEnabled, Color3.fromRGB(80,50,160))
end)

wallsToggle.MouseButton1Click:Connect(function()
    wallsEnabled = flip(wallsToggle, wallsEnabled, Color3.fromRGB(200,120,40))
end)

espToggle.MouseButton1Click:Connect(function()
    espEnabled = flip(espToggle, espEnabled, Color3.fromRGB(200,80,80))
end)

-- TP (fixed)
tpButton.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    local sub = workspace:FindFirstChild("Sublevel")
    local exit = sub and sub:FindFirstChild("Exit")

    if root and exit then
        if exit:IsA("BasePart") then
            root.CFrame = exit.CFrame + Vector3.new(0,5,0)
        elseif exit:IsA("Model") then
            local part = exit.PrimaryPart or exit:FindFirstChildWhichIsA("BasePart")
            if part then
                root.CFrame = part.CFrame + Vector3.new(0,5,0)
            end
        end
    end
end)

-- Functions

local function fireClicks()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            pcall(fireclickdetector, obj)
        end
    end
end

local function deleteFake()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("fake") then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function deleteWraith()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name:lower():find("wraith") then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function deleteFakeWalls()
    local sub = workspace:FindFirstChild("Sublevel")
    local fw = sub and sub:FindFirstChild("Walls") and sub.Walls:FindFirstChild("FakeWalls")
    if fw then
        for _, v in ipairs(fw:GetChildren()) do
            pcall(function() v:Destroy() end)
        end
    end
end

-- 👁 ESP (simple legit)
local function espWalls()
    local sub = workspace:FindFirstChild("Sublevel")
    local fw = sub and sub:FindFirstChild("Walls") and sub.Walls:FindFirstChild("FakeWalls")
    if not fw then return end

    for _, obj in ipairs(fw:GetDescendants()) do
        if obj:IsA("BasePart") then
            if not obj:FindFirstChild("ESP") then
                local h = Instance.new("Highlight")
                h.Name = "ESP"
                h.FillColor = Color3.fromRGB(255,80,80)
                h.FillTransparency = 0.6
                h.OutlineTransparency = 0
                h.Adornee = obj
                h.Parent = obj
            end

            obj.Transparency = 0.5
        end
    end
end

-- Loop (no optimization)
RunService.Heartbeat:Connect(function()
    if clickEnabled then fireClicks() end
    if fakeEnabled then deleteFake() end
    if wraithEnabled then deleteWraith() end
    if wallsEnabled then deleteFakeWalls() end
    if espEnabled then espWalls() end
end)
