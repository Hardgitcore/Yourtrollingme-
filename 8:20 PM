-- States
local clickEnabled, fakeEnabled, wraithEnabled, wallsEnabled, espEnabled = false,false,false,false,false

local function flip(btn, state, color)
    state = not state
    btn.Text = state and "Disable" or "Enable"
    btn.BackgroundColor3 = state and Color3.fromRGB(200,60,60) or color
    return state
end

