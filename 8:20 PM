    bar.BackgroundColor3 = accentColor
    bar.BorderSizePixel = 0
    bar.Parent = btn
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)

    local btnText = Instance.new("TextLabel")
    btnText.Size = UDim2.new(1, -14, 1, 0)
    btnText.Position = UDim2.new(0, 14, 0, 0)
    btnText.BackgroundTransparency = 1
    btnText.Text = "ENABLE"
    btnText.TextColor3 = Color3.fromRGB(200, 200, 220)
    btnText.TextSize = 11
    btnText.Font = Enum.Font.GothamBold
    btnText.TextXAlignment = Enum.TextXAlignment.Left
    btnText.Parent = btn

    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0, 42, 0, 16)
    pill.Position = UDim2.new(1, -48, 0.5, -8)
    pill.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    pill.BorderSizePixel = 0
    pill.Parent = btn
