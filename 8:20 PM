        if obj:IsA("ClickDetector") then
            pcall(fireclickdetector, obj)
            fireCount += 1
            countLabel.Text = "Fired: " .. fireCount
        end
    end
end

local LAP_FOLDERS = {"Lap1","Lap2","Lap3","Lap4"}

local function scanAndDeleteKeyword(folder, keyword)
    if not folder then return end
    for _, obj in ipairs(folder:GetChildren()) do
        if string.find(obj.Name:lower(), keyword) then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function deleteFakeObjects()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end

    scanAndDeleteKeyword(sub, "fake")
    for _, f in ipairs(LAP_FOLDERS) do
        scanAndDeleteKeyword(sub:FindFirstChild(f), "fake")
    end
end

local function deleteWraithObjects()
    local sub = workspace:FindFirstChild("Sublevel")
    if not sub then return end

    for _, f in ipairs(LAP_FOLDERS) do
        scanAndDeleteKeyword(sub:FindFirstChild(f), "wraith")
    end
end

-- Loop
RunService.Heartbeat:Connect(function()
    if clickEnabled then fireAllClickDetectors() end
    if fakeEnabled then deleteFakeObjects() end
    if wraithEnabled then deleteWraithObjects() end
    if wallsEnabled then deleteFakeWalls() end
end)
