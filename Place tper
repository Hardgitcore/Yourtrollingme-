-- Create button
local function makeButton(name, placeId, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -8, 0, 36)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    btn.TextColor3 = Color3.fromRGB(220,220,255)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 12
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0
    btn.LayoutOrder = order
    btn.Parent = ScrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, 10)
    pad.Parent = btn

    -- Current place highlight
    if placeId == game.PlaceId then
        btn.BackgroundColor3 = Color3.fromRGB(0, 80, 160)
        btn.Text = "📍 " .. name .. " (here)"
    else
        btn.Text = "🌐 " .. name
    end

    -- Click handler
    btn.MouseButton1Click:Connect(function()
    if placeId == game.PlaceId then
        btn.Text = "⚠️ Already here!"
        return
    end

    btn.Text = "⏳ Teleporting..."

    local success = false

    -- Try TeleportAsync
    pcall(function()
        TeleportService:TeleportAsync(placeId, {lp})
        success = true
    end)

    task.wait(1)

    -- Fallback to Teleport
    if not success then
        pcall(function()
            TeleportService:Teleport(placeId, lp)
            success = true
        end)
    end

    -- If still failed
    if not success then
        btn.Text = "❌ Teleport blocked"
    end
end)

-- Fetch places
task.spawn(function()
    local ok, data = pcall(function()
        local url = "https://develop.roblox.com/v1/universes/" .. universeId .. "/places?limit=100&sortOrder=Asc"
        local res = httpGet(url)

        if not res or res.StatusCode ~= 200 then
            error("HTTP Error")
        end

        return HttpService:JSONDecode(res.Body)
    end)

    if not ok then
        StatusLabel.Text = "❌ Failed to fetch places"
        warn(data)
        return
    end

    local places = data and data.data
    if not places or #places == 0 then
        StatusLabel.Text = "❌ No places found"
        return
    end

    StatusLabel.Text = "✅ Found " .. #places .. " places"

    for i, place in ipairs(places) do
        makeButton(place.name or ("Place "..i), place.placeId, i)
    end

    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, #places * 41)
end)
