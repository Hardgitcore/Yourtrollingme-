-- ============================================================
-- HELPERS
-- ============================================================

local function getRoot()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = player.Character
    return char and char:FindFirstChildWhichIsA("Humanoid")
end

local function getSubLevel()
    return workspace:FindFirstChild("Sublevel")
end

-- ============================================================
-- CHASER
-- ============================================================

local function getChaser()
    local sub = getSubLevel()
    if not sub then return nil end
    local c = sub:FindFirstChild("Chaser")
    if c then return c end
    for _, obj in ipairs(sub:GetDescendants()) do
        if obj.Name == "Chaser" and (obj:IsA("Model") or obj:IsA("BasePart")) then
            return obj
        end
    end
    return nil
end

local function getChaserPosition()
    local chaser = getChaser()
    if not chaser then return nil end
    if chaser:IsA("Model") then
        local r = chaser:FindFirstChild("HumanoidRootPart")
            or chaser.PrimaryPart
            or chaser:FindFirstChildWhichIsA("BasePart")
        return r and r.Position or nil
    end
    return chaser:IsA("BasePart") and chaser.Position or nil
end

local function getChaserDistance()
    local root = getRoot()
    if not root then return math.huge end
    local cPos = getChaserPosition()
    if not cPos then return math.huge end
    return (root.Position - cPos).Magnitude
end

local function getFleePosition()
    local root = getRoot()
    if not root then return nil end
    local cPos = getChaserPosition()
    if not cPos then return nil end
    local away = root.Position - cPos
    if away.Magnitude < 0.1 then
        away = Vector3.new(math.random(-1,1), 0, math.random(-1,1))
    end
    away = Vector3.new(away.X, 0, away.Z).Unit
    return root.Position + away * CHASER_FLEE_DIST
end

-- ============================================================
-- SCANNER — builds game state for AI
-- ============================================================

local function scanGameState()
    local root    = getRoot()
    local sub     = getSubLevel()
    local state   = {}

    state.playerPos   = root and tostring(root.Position) or "unknown"
    state.chaserDist  = math.floor(getChaserDistance())
    state.chaserPos   = getChaserPosition() and tostring(getChaserPosition()) or "not found"
    state.inDanger    = getChaserDistance() < CHASER_DANGER_DIST

    state.exits          = {}
    state.buttons        = {}
    state.clickDetectors = {}
    state.proximityPrompts = {}
    state.checkpoints    = {}

    if sub then
        for _, obj in ipairs(sub:GetDescendants()) do
            local n = obj.Name:lower()
            if n:find("fake") or n:find("wraith") then continue end

            -- Exit
            if n == "exit" or n:find("exit") then
                local pos = nil
                if obj:IsA("BasePart") then pos = obj.Position
                elseif obj:IsA("Model") then
                    local p = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                    if p then pos = p.Position end
                end
                if pos and root then
                    table.insert(state.exits, {
                        name = obj.Name,
                        dist = math.floor((root.Position - pos).Magnitude),
                        pos  = tostring(pos)
                    })
                end
            end

            -- Buttons
            if n == "button" or n:find("button") then
                if obj:IsA("BasePart") and root then
                    table.insert(state.buttons, {
                        name = obj.Name,
                        dist = math.floor((root.Position - obj.Position).Magnitude),
                        pos  = tostring(obj.Position)
                    })
                end
            end

            -- ClickDetectors
            if obj:IsA("ClickDetector") then
                local part = obj.Parent
                if part and part:IsA("BasePart") and root then
                    table.insert(state.clickDetectors, {
                        name = part.Name,
                        dist = math.floor((root.Position - part.Position).Magnitude),
                        pos  = tostring(part.Position)
                    })
                end
            end

            -- ProximityPrompts
            if obj:IsA("ProximityPrompt") then
                local part = obj.Parent
                if part and part:IsA("BasePart") and root then
                    table.insert(state.proximityPrompts, {
                        name = part.Name,
                        dist = math.floor((root.Position - part.Position).Magnitude),
                        pos  = tostring(part.Position)
                    })
                end
            end

            -- Checkpoints
            if obj:IsA("BasePart") and (n:find("checkpoint") or n:find("start") or n:find("waypoint")) then
                if root then
                    table.insert(state.checkpoints, {
                        name = obj.Name,
                        dist = math.floor((root.Position - obj.Position).Magnitude),
                        pos  = tostring(obj.Position)
                    })
                end
            end
        end
    end

    -- Sort all by distance
    local function sortByDist(t)
        table.sort(t, function(a, b) return a.dist < b.dist end)
    end
    sortByDist(state.exits)
    sortByDist(state.buttons)
    sortByDist(state.clickDetectors)
    sortByDist(state.proximityPrompts)
    sortByDist(state.checkpoints)

    -- Lap buttons (specific known structure)
    state.lapButtons = {}
    if sub then
        for lapNum = 1, 4 do
            local lap = sub:FindFirstChild("Lap" .. lapNum)
            if lap then
                local children = lap:GetChildren()
                if children[3] then
                    local btn = children[3]:FindFirstChild("Button")
                        or (children[3].Name == "Button" and children[3])
                    if btn and btn:IsA("BasePart") and root then
                        table.insert(state.lapButtons, {
                            name = "Lap"..lapNum.."Button",
                            dist = math.floor((root.Position - btn.Position).Magnitude),
                            pos  = tostring(btn.Position)
                        })
                    end
                end
            end
        end
        sortByDist(state.lapButtons)
    end

    return state
end

-- ============================================================
-- GROQ API CALL
-- Returns { action, targetPos, reason } or nil on failure
-- Actions: "move_exit", "move_button", "move_cd", "move_pp",
--          "move_checkpoint", "flee", "fire_all", "wait"
-- ============================================================

local function callGroqAI(state)
    local prompt = string.format([[
You are the AI brain of a Roblox horror game autoplayer. Your ONLY goal is to reach the Exit without being touched by the Chaser.

Current game state (JSON):
%s

Rules:
- If inDanger is true OR chaserDist < %d, you MUST flee immediately
- Priority order: flee > reach exit > press buttons/click detectors > move to checkpoints
- Lap buttons (lapButtons) are important — pressing them unlocks progress
- Click detectors within %d studs should be fired while moving
- Always pick the closest relevant target
- Never move toward the chaser

Respond with ONLY valid JSON, no markdown, no explanation. Format:
{
  "action": "flee|move_exit|move_button|move_lapbutton|move_cd|move_pp|move_checkpoint|fire_all|wait",
  "targetName": "name of target or empty string",
  "targetPos": "x, y, z numbers as string or empty string",
  "reason": "one short sentence"
}
]], HttpService:JSONEncode(state), CHASER_DANGER_DIST, INTERACT_RANGE)

    local body = HttpService:JSONEncode({
        model = GROQ_MODEL,
        messages = {
            {
                role = "system",
                content = "You are a Roblox game AI. Respond only with valid JSON decisions. No markdown, no backticks."
            },
            {
                role = "user",
                content = prompt
            }
        },
        max_tokens = 200,
        temperature = 0.2
    })

    local ok, result = pcall(function()
        return game:GetService("HttpService"):RequestAsync({
            Url    = "https://api.groq.com/openai/v1/chat/completions",
            Method = "POST",
            Headers = {
                ["Content-Type"]  = "application/json",
                ["Authorization"] = "Bearer " .. GROQ_API_KEY
            },
            Body = body
        })
    end)

    if not ok or not result or result.StatusCode ~= 200 then
        warn("Groq API error:", result and result.StatusCode, result and result.Body)
        return nil
    end

    local decoded = pcall(function()
        result = HttpService:JSONDecode(result.Body)
    end)

    local text = result
        and result.choices
        and result.choices[1]
        and result.choices[1].message
        and result.choices[1].message.content

    if not text then return nil end

    -- Strip any accidental markdown fences
    text = text:gsub("```json", ""):gsub("```", ""):match("^%s*(.-)%s*$")

    local ok2, decision = pcall(function()
        return HttpService:JSONDecode(text)
    end)

    if not ok2 or not decision then
        warn("Failed to parse AI response:", text)
        return nil
    end

    return decision
end

-- ============================================================
-- MOVEMENT (PATHFINDING FIXED)
-- ============================================================

local currentTargetPos = nil
local moveConnection = nil
local currentPath = nil

local function stopCurrentMovement()
    if moveConnection then
        pcall(function() moveConnection:Disconnect() end)
        moveConnection = nil
    end
    currentPath = nil
end

local function moveToWithPath(targetPos)
    local hum = getHumanoid()
    local root = getRoot()
    if not hum or not root then return end

    -- prevent spam
    if currentTargetPos and (currentTargetPos - targetPos).Magnitude < 4 then
        return
    end

    currentTargetPos = targetPos
    stopCurrentMovement()

    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentJumpHeight = 7,
        AgentMaxSlope = 45
    })

    local success = pcall(function()
        path:ComputeAsync(root.Position, targetPos)
    end)

    if not success or path.Status ~= Enum.PathStatus.Success then
        moveToWithPath(targetPos) -- fallback
        return
    end

    currentPath = path
    local waypoints = path:GetWaypoints()
    local waypointIndex = 1

    local function moveNext()
        if not autoEnabled then return end
        if waypointIndex > #waypoints then return end

        local wp = waypoints[waypointIndex]

        if wp.Action == Enum.PathWaypointAction.Jump then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end

        hum:MoveTo(wp.Position)

        -- keep interacting while moving
        fireAllNearby()
        fireLapButtons()
    end

    moveConnection = hum.MoveToFinished:Connect(function(reached)
        if not autoEnabled then return end

        if reached then
            waypointIndex += 1
            moveNext()
        else
            moveToWithPath(targetPos)
        end
    end)

    path.Blocked:Connect(function()
        moveToWithPath(targetPos)
    end)

    moveNext()
end

-- ============================================================
-- CHASER MONITOR
-- ============================================================

local monitorConn = nil

local function startChaserMonitor()
    if monitorConn then pcall(function() monitorConn:Disconnect() end) end
    monitorConn = RunService.Heartbeat:Connect(function()
        if not autoEnabled then return end
        local dist = getChaserDistance()
        if dist < math.huge then
            chaserLbl.Text = "Chaser: " .. math.floor(dist) .. " studs"
            if dist < CHASER_DANGER_DIST then
                chaserLbl.TextColor3 = Color3.fromRGB(255, 60, 60)
            elseif dist < CHASER_DANGER_DIST * 2 then
                chaserLbl.TextColor3 = Color3.fromRGB(255, 180, 30)
            else
                chaserLbl.TextColor3 = Color3.fromRGB(80, 200, 80)
            end
        else
            chaserLbl.Text       = "Chaser: Not found"
            chaserLbl.TextColor3 = Color3.fromRGB(80, 200, 80)
        end
    end)
end

local function stopChaserMonitor()
    if monitorConn then
        pcall(function() monitorConn:Disconnect() end)
        monitorConn = nil
    end
end

-- ============================================================
-- MAIN AI LOOP
-- ============================================================

local aiLoopConn = nil

local function startAILoop()
    if aiLoopConn then pcall(function() aiLoopConn:Disconnect() end) end

    aiLoopConn = RunService.Heartbeat:Connect(function()
        if not autoEnabled then return end

        local now = tick()
        if now - lastAICall < AI_DECISION_EVERY then return end
        lastAICall = now

        -- Emergency flee overrides AI if chaser is right on top of us
        if getChaserDistance() < CHASER_DANGER_DIST * 0.6 then
            local hum = getHumanoid()
            local fp  = getFleePosition()
            if hum and fp then
                hum:MoveTo(fp)
                actionLbl.Text = "Action: emergency flee"
                chaserLbl.TextColor3 = Color3.fromRGB(255, 60, 60)
            end
            return
        end

        -- Async AI call so it doesn't block Heartbeat
        task.spawn(function()
            statusLbl.Text = "Status: Thinking..."
            local state    = scanGameState()
            local decision = callGroqAI(state)

            if not autoEnabled then return end

            if decision then
                statusLbl.Text = "Status: Running"
                executeAction(decision)
            else
                -- Fallback: fire all nearby and keep moving to last target
                statusLbl.Text = "Status: AI error — fallback"
                fireAllNearby()
                fireLapButtons()
                local hum  = getHumanoid()
                local root = getRoot()
                if hum and currentTarget and root then
                    if (root.Position - currentTarget).Magnitude > WAYPOINT_REACH then
                        hum:MoveTo(currentTarget)
                    end
                end
            end
        end)
    end)
end

local function stopAILoop()
    if aiLoopConn then
        pcall(function() aiLoopConn:Disconnect() end)
        aiLoopConn = nil
    end
end

