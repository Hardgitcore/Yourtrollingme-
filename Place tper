local function makeButton(name, placeId, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -8, 0, 36)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    btn.TextColor3 = Color3.fromRGB(220, 220, 255)
    btn.Text = "🌐 " .. name
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 12
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0
    btn.LayoutOrder = order
    btn.Parent = ScrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, 10)
    pad.Parent = btn

    -- Highlight current place
    if placeId == game.PlaceId then
        btn.BackgroundColor3 = Color3.fromRGB(0, 80, 160)
        btn.Text = "📍 " .. name .. " (here)"
    end

    btn.MouseButton1Click:Connect(function()
    btn.MouseButton1Click:Connect(function()
    if placeId == game.PlaceId then
        btn.Text = "⚠️ Already here!"
        task.delay(1.5, function()
            btn.Text = "📍 " .. name .. " (here)"
        end)
        return
    end
    btn.Text = "⏳ Teleporting..."
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 60)

    local options = Instance.new("TeleportOptions")
    options.ShouldReserveServer = false

    local ok, err = pcall(function()
        TeleportService:TeleportAsync(placeId, {lp}, options)
    end)

    if not ok then
        btn.Text = "❌ Failed: " .. tostring(err):sub(1, 30)
        btn.BackgroundColor3 = Color3.fromRGB(120, 30, 30)
    end
end)

-- Fetch places from Roblox API
task.spawn(function()
    local ok, result = pcall(function()
        local url = "https://develop.roblox.com/v1/universes/" .. universeId .. "/places?sortOrder=Asc&limit=50"
        local res = httpGet(url)
        if not res or res.StatusCode ~= 200 then
            error("HTTP " .. (res and res.StatusCode or "nil"))
        end
        return game:GetService("HttpService"):JSONDecode(res.Body)
    end)

    if not ok then
        StatusLabel.Text = "❌ Failed: " .. tostring(result)
        return
    end

    local places = result and result.data
    if not places or #places == 0 then
        StatusLabel.Text = "❌ No places found."
        return
    end

    StatusLabel.Text = "✅ Found " .. #places .. " place(s)"

    for i, place in ipairs(places) do
        makeButton(place.name or "Place " .. i, place.placeId, i)
    end

    -- Resize scroll canvas
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, #places * 41)
end)
