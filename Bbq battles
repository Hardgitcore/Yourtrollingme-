                                eatRemote:FireServer(stick)
                            end
                        end
                    end)
                end
            end)
        else
            if connections.eat then connections.eat:Disconnect() connections.eat = nil end
        end
    end,
})

Tab:CreateSection("Combat")

Tab:CreateToggle({
    Name = "Hitbox Expander",
    CurrentValue = false,
    Flag = "HitboxToggle",
    Callback = function(state)
        hitboxEnabled = state
        updateAllHitboxes()
    end,
})

Tab:CreateSlider({
    Name = "Hitbox Size",
    Range = {2, 50},
    Increment = 1,
