--- Logic Connections ---

-- Function to handle a single player's character life cycle
local function monitorPlayer(player)
    -- Apply to their current character if they have one
    if player.Character then
        applyHitbox(player.Character)
    end

    -- Apply every time they respawn in the future
    player.CharacterAdded:Connect(function(char)
        task.wait(1) -- Wait for the character to actually exist in the workspace
        applyHitbox(char)
    end)
end

-- 1. Setup listeners for all players CURRENTLY in the server
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= Players.LocalPlayer then
        monitorPlayer(player)
    end
end

-- 2. Setup listeners for anyone who JOINS later
Players.PlayerAdded:Connect(function(player)
    monitorPlayer(player)
end)

