local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local spinRemote = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("SpinWheelEvent")
local eatRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Eat")
local claimRemote = ReplicatedStorage:WaitForChild("ClaimCoinsPopUp")

local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name = "BBQ Hub",
    LoadingTitle = "Bake n eat",
    LoadingSubtitle = "YummersYam",
    Theme = "Amethyst",
    DisableRayfieldPrompts = true,
    DisableBuildWarnings = true,
})

local Tab = Window:CreateTab("Main", 4483362458)

-- Shared state
local connections = {}
local timers = { claim = 0, spin = 0, eat = 0 }
local interval = 1
local claimCount = 0

local label = Tab:CreateLabel("Claimed: 0 times")

Tab:CreateSlider({
    Name = "Fire Interval (seconds)",
    Range = {0.5, 10},
    Increment = 0.5,
    Suffix = "s",
    CurrentValue = 1,
    Flag = "Interval",
    Callback = function(val)
        interval = val
    end,
})

Tab:CreateSection("Coin Claimer")

Tab:CreateToggle({
    Name = "Bunch of coins",
    CurrentValue = false,
    Flag = "AutoClaim",
    Callback = function(state)
        if state then
            connections.claim = RunService.Heartbeat:Connect(function(dt)
                timers.claim += dt
                if timers.claim >= interval then
                    timers.claim = 0
                    claimCount += 1
                    pcall(function() claimRemote:FireServer() end)
                    label:Set("Claimed: " .. claimCount .. " times")
                end
            end)
        else
            if connections.claim then connections.claim:Disconnect() connections.claim = nil end
        end
    end,
})

Tab:CreateButton({
    Name = "Reset Count",
    Callback = function()
        claimCount = 0
        label:Set("Claimed: 0 times")
    end,
})

Tab:CreateSection("Spin Wheel")

Tab:CreateToggle({
    Name = "Auto Spin",
    CurrentValue = false,
    Flag = "AutoSpin",
    Callback = function(state)
        if state then
            connections.spin = RunService.Heartbeat:Connect(function(dt)
                timers.spin += dt
                if timers.spin >= interval then
                    timers.spin = 0
                    pcall(function() spinRemote:FireServer(unpack({"Normal"})) end)
                end
            end)
        else
            if connections.spin then connections.spin:Disconnect() connections.spin = nil end
        end
    end,
})

Tab:CreateSection("Eat")

Tab:CreateToggle({
    Name = "Auto Eat",
    CurrentValue = false,
    Flag = "AutoEat",
    Callback = function(state)
        if state then
            connections.eat = RunService.Heartbeat:Connect(function(dt)
                timers.eat += dt
                if timers.eat >= interval then
                    timers.eat = 0
                    pcall(function()
                        local char = Players.LocalPlayer.Character
                        if char then
                            local stick = char:FindFirstChild("Stick")
                            if stick then
                                eatRemote:FireServer(stick)
                            end
                        end
                    end)
                end
            end)
        else
            if connections.eat then connections.eat:Disconnect() connections.eat = nil end
        end
    end,
})

Rayfield:Notify({
    Title = "BBQ Battles",
    Content = "Loaded",
    Duration = 3,
})
