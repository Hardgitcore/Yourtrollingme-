-- Remote reference
local remote = ReplicatedStorage
    :WaitForChild("rbxts_include")
    :WaitForChild("node_modules")
    :WaitForChild("@rbxts")
    :WaitForChild("remo")
    :WaitForChild("src")
    :WaitForChild("container")
    :WaitForChild("terrain.clientRemovedTerrain")

local args = {
    vector.create(38.15892791748047, -16.839773178100586, -219.25625610351562)
}

-- Logic
local running = false
local thread = nil
local INTERVAL = 1

local function startLoop()
    running = true
    button.Text = "Stop"
    button.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    statusLabel.TextColor3 = Color3.fromRGB(100, 220, 100)
    statusLabel.Text = "Status: Running"

    thread = task.spawn(function()
        while running do
            remote:FireServer(unpack(args))
            for i = INTERVAL, 1, -1 do
                if not running then break end
                countdownLabel.Text = "Next fire: " .. i .. "s"
                task.wait(1)
            end
        end
    end)
end

local function stopLoop()
    running = false
    if thread then
        task.cancel(thread)
        thread = nil
    end
    button.Text = "Start"
    button.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
    statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    statusLabel.Text = "Status: Stopped"
    countdownLabel.Text = "Next fire: --s"
end

button.MouseButton1Click:Connect(function()
    if running then
        stopLoop()
    else
        startLoop()
    end
end)
